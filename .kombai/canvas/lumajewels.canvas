      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --ghost-white: #F8F8FF;\n    --soft-blossom: #F2BDCD;\n    --carbon-black: #1B1B1B;\n  }\n\n  body {\n    background-color: var(--ghost-white);\n    color: var(--carbon-black);\n    font-family: 'DM Sans', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-fraunces { font-family: 'Fraunces', serif; }\n  .font-dmsans { font-family: 'DM Sans', sans-serif; }\n\n  .blob-mask { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; will-change: transform; }\n  .blob-mask-alt { border-radius: 40% 60% 70% 30% / 30% 70% 40% 60%; will-change: transform; }\n\n  .hide-scrollbar::-webkit-scrollbar { display: none; }\n  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n\n  .marquee-container {\n    overflow: hidden;\n    white-space: nowrap;\n    width: 100%;\n    border-top: 1px solid rgba(27, 27, 27, 0.05);\n    border-bottom: 1px solid rgba(27, 27, 27, 0.05);\n    padding: 1.5rem 0;\n  }\n\n  .stagger-card { will-change: transform, opacity; }\n\n  .rotate-text {\n    writing-mode: vertical-rl;\n    transform: rotate(180deg);\n  }\n\n  .quiz-radio:checked + div {\n    border-color: var(--carbon-black);\n    background-color: white;\n  }\n\n  .quiz-radio:checked + div .radio-circle {\n    background-color: var(--carbon-black);\n  }\n\n  html.lenis { height: auto; }\n  .lenis.lenis-smooth { scroll-behavior: auto; }\n  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }\n</style>\n\n\n<nav class=\"fixed top-0 left-0 w-full z-50 px-12 py-6 flex justify-between items-center mix-blend-difference text-white\" data-kid=\"1\">\n  <div class=\"text-2xl font-fraunces font-bold italic tracking-tight\" data-kid=\"2\">Luma</div>\n  <div class=\"hidden md:flex gap-10 text-[9px] uppercase tracking-[0.2em] font-medium\" data-kid=\"3\">\n    <a href=\"#collections\" class=\"hover:text-[var(--soft-blossom)] transition-colors\" data-kid=\"4\">Collections</a>\n    <a href=\"#ai-stylist\" class=\"hover:text-[var(--soft-blossom)] transition-colors\" data-kid=\"5\">AI Stylist</a>\n    <a href=\"#bespoke\" class=\"hover:text-[var(--soft-blossom)] transition-colors\" data-kid=\"6\">Bespoke</a>\n    <a href=\"#about\" class=\"hover:text-[var(--soft-blossom)] transition-colors\" data-kid=\"7\">Journal</a>\n  </div>\n  <div class=\"flex items-center gap-6\" data-kid=\"8\">\n    <i class=\"ti ti-search text-lg cursor-pointer\" data-kid=\"9\"></i>\n    <div class=\"relative cursor-pointer\" data-kid=\"10\">\n      <i class=\"ti ti-shopping-bag text-lg\" data-kid=\"11\"></i>\n      <span class=\"absolute -top-1 -right-1 bg-[var(--soft-blossom)] text-[var(--carbon-black)] text-[7px] font-bold w-3.5 h-3.5 rounded-full flex items-center justify-center\" data-kid=\"12\">2</span>\n    </div>\n  </div>\n</nav>\n\n\n<main data-kid=\"13\">\n  <section class=\"min-h-screen flex flex-col md:flex-row relative\" data-kid=\"14\">\n    \n    <div class=\"hidden md:flex w-24 border-r border-[var(--carbon-black)]/5 flex-col items-center justify-between py-12 relative\" data-kid=\"15\">\n        <div class=\"rotate-text text-[9px] uppercase tracking-[0.3em] opacity-40 whitespace-nowrap\" data-kid=\"16\">\n          The Convergence of Art & Intelligence\n        </div>\n        <div class=\"flex flex-col gap-6 opacity-20\" data-kid=\"17\">\n          <i class=\"ti ti-brand-instagram\" data-kid=\"18\"></i>\n          <i class=\"ti ti-brand-pinterest\" data-kid=\"19\"></i>\n        </div>\n    </div>\n\n    \n    <div class=\"flex-1 p-8 md:p-16 flex flex-col justify-center\" data-kid=\"20\">\n      <div class=\"max-w-5xl mt-12\" data-kid=\"21\">\n        <h1 class=\"text-[clamp(3.5rem,8vw,6rem)] font-fraunces leading-[0.85] mb-12 tracking-tighter\" data-kid=\"22\">\n          Eternal <br data-kid=\"23\"> <span class=\"italic font-light text-[var(--soft-blossom)]\" data-kid=\"24\">Intelligence</span>\n        </h1>\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-12 gap-12 items-end\" data-kid=\"25\">\n          <div class=\"md:col-span-8 relative rounded-2xl overflow-hidden shadow-sm aspect-[16/10]\" data-kid=\"26\">\n            <video src=\"https://videos.pexels.com/video-files/6263177/6263177-uhd_2560_1440_25fps.mp4\" poster=\"https://images.pexels.com/videos/6263177/pexels-photo-6263177.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" class=\"w-full h-full object-cover\" autoplay muted loop playsinline data-kid=\"27\"></video>\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--carbon-black)]/20 to-transparent\" data-kid=\"28\"></div>\n          </div>\n          \n          <div class=\"md:col-span-4 space-y-8 pb-4\" data-kid=\"29\">\n            <p class=\"text-sm leading-relaxed opacity-60 font-dmsans\" data-kid=\"30\">\n              LumaJewels AI bridges the gap between digital intuition and artisanal craft. Every piece is curated by our proprietary aesthetic engine.\n            </p>\n            <button class=\"group relative px-8 py-4 bg-[var(--carbon-black)] text-white rounded-full text-[10px] uppercase tracking-widest overflow-hidden\" data-kid=\"31\">\n              <span class=\"relative z-10\" data-kid=\"32\">Discover Your Match</span>\n              <div class=\"absolute inset-0 bg-[var(--soft-blossom)] translate-y-full group-hover:translate-y-0 transition-transform duration-500\" data-kid=\"33\"></div>\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"w-full md:w-[450px] p-8 md:p-12 flex flex-col justify-center gap-6 md:border-l border-[var(--carbon-black)]/5\" data-kid=\"34\">\n      <span class=\"text-[9px] uppercase tracking-widest opacity-40\" data-kid=\"35\">AI Selection &mdash; Vol. 12</span>\n      \n      <div class=\"stagger-card flex items-center gap-6 p-4 rounded-2xl hover:bg-white transition-colors cursor-pointer group\" data-kid=\"36\">\n        <div class=\"w-24 h-24 rounded-xl overflow-hidden bg-white shadow-xs\" data-kid=\"37\">\n          <img src=\"https://images.pexels.com/photos/1457801/pexels-photo-1457801.jpeg?auto=format&w=200&q=80\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" alt=\"Rose Radiance\" loading=\"lazy\" decoding=\"async\" data-kid=\"38\">\n        </div>\n        <div data-kid=\"39\">\n          <h3 class=\"font-fraunces text-lg\" data-kid=\"40\">Rose Radiance</h3>\n          <p class=\"text-[10px] opacity-40 uppercase tracking-widest\" data-kid=\"41\">$2,400 &bull; 98% Match</p>\n        </div>\n      </div>\n\n      <div class=\"stagger-card flex items-center gap-6 p-4 rounded-2xl hover:bg-white transition-colors cursor-pointer group\" data-kid=\"42\">\n        <div class=\"w-24 h-24 rounded-xl overflow-hidden bg-[var(--ghost-white)]\" data-kid=\"43\">\n          <img src=\"https://images.pexels.com/photos/265856/pexels-photo-265856.jpeg?auto=format&w=200&q=80\" class=\"w-full h-full object-cover\" alt=\"Astral Chain\" loading=\"lazy\" decoding=\"async\" data-kid=\"44\">\n        </div>\n        <div data-kid=\"45\">\n          <h3 class=\"font-fraunces text-lg\" data-kid=\"46\">Astral Chain</h3>\n          <p class=\"text-[10px] opacity-40 uppercase tracking-widest\" data-kid=\"47\">$1,850 &bull; 94% Match</p>\n        </div>\n      </div>\n\n      <div class=\"stagger-card flex items-center gap-6 p-4 rounded-2xl hover:bg-white transition-colors cursor-pointer group\" data-kid=\"48\">\n        <div class=\"w-24 h-24 rounded-xl overflow-hidden bg-[var(--ghost-white)]\" data-kid=\"49\">\n          <img src=\"https://images.pexels.com/photos/2849742/pexels-photo-2849742.jpeg?auto=format&w=200&q=80\" class=\"w-full h-full object-cover\" alt=\"Petal Droplets\" loading=\"lazy\" decoding=\"async\" data-kid=\"50\">\n        </div>\n        <div data-kid=\"51\">\n          <h3 class=\"font-fraunces text-lg\" data-kid=\"52\">Petal Droplets</h3>\n          <p class=\"text-[10px] opacity-40 uppercase tracking-widest\" data-kid=\"53\">$920 &bull; 91% Match</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"marquee-container bg-white\" data-kid=\"54\">\n    <div class=\"marquee-track flex whitespace-nowrap\" data-kid=\"55\">\n      <div class=\"marquee-content font-fraunces text-xl uppercase tracking-[0.3em] flex items-center\" data-kid=\"56\">\n        <span data-kid=\"57\">Crafted for gifting</span>\n        <i class=\"ti ti-star-filled text-[var(--soft-blossom)] mx-4\" data-kid=\"58\"></i>\n        <span data-kid=\"59\">AI-powered personalization</span>\n        <i class=\"ti ti-star-filled text-[var(--soft-blossom)] mx-4\" data-kid=\"60\"></i>\n        <span data-kid=\"61\">Secure luxury checkout</span>\n        <i class=\"ti ti-star-filled text-[var(--soft-blossom)] mx-4\" data-kid=\"62\"></i>\n        <span data-kid=\"63\">Ethically sourced diamonds</span>\n        <i class=\"ti ti-star-filled text-[var(--soft-blossom)] mx-4\" data-kid=\"64\"></i>\n        \n        <span data-kid=\"65\">Crafted for gifting</span>\n        <i class=\"ti ti-star-filled text-[var(--soft-blossom)] mx-4\" data-kid=\"66\"></i>\n        <span data-kid=\"67\">AI-powered personalization</span>\n        <i class=\"ti ti-star-filled text-[var(--soft-blossom)] mx-4\" data-kid=\"68\"></i>\n        <span data-kid=\"69\">Secure luxury checkout</span>\n        <i class=\"ti ti-star-filled text-[var(--soft-blossom)] mx-4\" data-kid=\"70\"></i>\n        <span data-kid=\"71\">Ethically sourced diamonds</span>\n        <i class=\"ti ti-star-filled text-[var(--soft-blossom)] mx-4\" data-kid=\"72\"></i>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"collections\" class=\"py-24 md:py-32 overflow-hidden\" data-kid=\"73\">\n    <div class=\"px-8 md:px-16 mb-16 flex justify-between items-end\" data-kid=\"74\">\n      <div data-kid=\"75\">\n        <span class=\"text-[9px] uppercase tracking-widest opacity-40 mb-3 block\" data-kid=\"76\">Selected Works</span>\n        <h2 class=\"text-5xl md:text-6xl font-fraunces\" data-kid=\"77\">The <span class=\"italic\" data-kid=\"78\">Curated</span> Edit</h2>\n      </div>\n      <div class=\"flex gap-3\" data-kid=\"79\">\n        <button class=\"carousel-prev w-12 h-12 rounded-full border border-[var(--carbon-black)]/10 flex items-center justify-center hover:bg-[var(--carbon-black)] hover:text-white transition-all duration-300\" data-kid=\"80\">\n          <i class=\"ti ti-arrow-left\" data-kid=\"81\"></i>\n        </button>\n        <button class=\"carousel-next w-12 h-12 rounded-full border border-[var(--carbon-black)]/10 flex items-center justify-center hover:bg-[var(--carbon-black)] hover:text-white transition-all duration-300\" data-kid=\"82\">\n          <i class=\"ti ti-arrow-right\" data-kid=\"83\"></i>\n        </button>\n      </div>\n    </div>\n\n    <div class=\"carousel-track flex gap-8 md:gap-12 px-8 md:px-16 overflow-x-auto hide-scrollbar snap-x\" data-kid=\"84\">\n      \n      <div class=\"min-w-[320px] md:min-w-[480px] group snap-start\" data-kid=\"85\">\n        <div class=\"w-full aspect-[4/5] bg-[var(--soft-blossom)]/5 rounded-2xl p-6 md:p-12 flex items-center justify-center relative overflow-hidden transition-colors hover:bg-[var(--soft-blossom)]/10 duration-500\" data-kid=\"86\">\n          <div class=\"blob-mask w-full h-full bg-white overflow-hidden\" data-kid=\"87\">\n            <img src=\"https://images.pexels.com/photos/1457801/pexels-photo-1457801.jpeg?auto=format&w=800&q=80\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-1000\" alt=\"Zenith Collection\" data-kid=\"88\">\n          </div>\n          <div class=\"absolute bottom-10 left-10 text-[var(--carbon-black)]\" data-kid=\"89\">\n            <span class=\"text-[9px] uppercase tracking-widest opacity-30 block mb-1\" data-kid=\"90\">Narrative 01</span>\n            <h3 class=\"text-2xl font-fraunces italic\" data-kid=\"91\">Zenith Horizon</h3>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"min-w-[500px] group snap-start\" data-kid=\"92\">\n        <div class=\"w-full aspect-[4/5] bg-[var(--carbon-black)]/5 rounded-[3rem] p-12 flex items-center justify-center relative overflow-hidden\" data-kid=\"93\">\n          <div class=\"blob-mask-alt w-full h-full bg-white overflow-hidden transition-all duration-1000 group-hover:scale-105\" data-kid=\"94\">\n            <img src=\"https://images.pexels.com/photos/265856/pexels-photo-265856.jpeg?auto=format&w=800&q=80\" class=\"w-full h-full object-cover\" alt=\"Silk Thread\" data-kid=\"95\">\n          </div>\n          <div class=\"absolute bottom-12 left-12 text-[var(--carbon-black)]\" data-kid=\"96\">\n            <span class=\"text-[10px] uppercase tracking-[0.4em] opacity-40 block mb-2\" data-kid=\"97\">Narrative 02</span>\n            <h3 class=\"text-3xl font-fraunces italic\" data-kid=\"98\">Silk & Shadow</h3>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"min-w-[500px] group snap-start\" data-kid=\"99\">\n        <div class=\"w-full aspect-[4/5] bg-[var(--soft-blossom)]/20 rounded-[3rem] p-12 flex items-center justify-center relative overflow-hidden\" data-kid=\"100\">\n          <div class=\"blob-mask w-full h-full bg-white overflow-hidden transition-all duration-1000 group-hover:scale-105\" data-kid=\"101\">\n            <img src=\"https://images.pexels.com/photos/2849742/pexels-photo-2849742.jpeg?auto=format&w=800&q=80\" class=\"w-full h-full object-cover\" alt=\"Organic Flow\" data-kid=\"102\">\n          </div>\n          <div class=\"absolute bottom-12 left-12 text-[var(--carbon-black)]\" data-kid=\"103\">\n            <span class=\"text-[10px] uppercase tracking-[0.4em] opacity-40 block mb-2\" data-kid=\"104\">Narrative 03</span>\n            <h3 class=\"text-3xl font-fraunces italic\" data-kid=\"105\">Organic Flow</h3>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"min-w-[500px] group snap-start\" data-kid=\"106\">\n        <div class=\"w-full aspect-[4/5] bg-[var(--carbon-black)]/5 rounded-[3rem] p-12 flex items-center justify-center relative overflow-hidden\" data-kid=\"107\">\n          <div class=\"blob-mask-alt w-full h-full bg-white overflow-hidden transition-all duration-1000 group-hover:scale-105\" data-kid=\"108\">\n            <img src=\"https://images.pexels.com/photos/948431/pexels-photo-948431.jpeg?auto=format&w=800&q=80\" class=\"w-full h-full object-cover\" alt=\"Prism Core\" data-kid=\"109\">\n          </div>\n          <div class=\"absolute bottom-12 left-12 text-[var(--carbon-black)]\" data-kid=\"110\">\n            <span class=\"text-[10px] uppercase tracking-[0.4em] opacity-40 block mb-2\" data-kid=\"111\">Narrative 04</span>\n            <h3 class=\"text-3xl font-fraunces italic\" data-kid=\"112\">Prism Core</h3>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 md:py-32 bg-white px-8 md:px-16 overflow-hidden\" data-kid=\"113\">\n    <div class=\"text-center mb-20\" data-kid=\"114\">\n      <span class=\"text-[9px] uppercase tracking-widest opacity-40 mb-3 block\" data-kid=\"115\">Personalized Proposal</span>\n      <h2 class=\"text-4xl md:text-5xl font-fraunces\" data-kid=\"116\">The <span class=\"italic\" data-kid=\"117\">Signature</span> Tier</h2>\n    </div>\n\n    <div class=\"flex flex-col md:flex-row gap-12 items-center mb-24\" data-kid=\"118\">\n      <div class=\"flex-1 space-y-8 order-2 md:order-1\" data-kid=\"119\">\n        <span class=\"inline-block px-3 py-1 bg-[var(--soft-blossom)]/20 rounded-full text-[10px] font-bold tracking-widest uppercase text-[var(--carbon-black)]\" data-kid=\"120\">99.8% Match</span>\n        <h3 class=\"text-5xl md:text-7xl font-fraunces leading-tight\" data-kid=\"121\">Your Aesthetic <br data-kid=\"122\">North Star</h3>\n        <p class=\"text-sm md:text-base opacity-50 max-w-md font-dmsans leading-relaxed\" data-kid=\"123\">\n          A one-of-a-kind algorithm-generated design proposal tailored exclusively for your profile, merging the ethereal with the structural.\n        </p>\n        <button class=\"text-[10px] uppercase tracking-widest font-bold border-b-2 border-[var(--carbon-black)] pb-1 hover:text-[var(--soft-blossom)] hover:border-[var(--soft-blossom)] transition-all\" data-kid=\"124\">Request Prototype</button>\n      </div>\n      <div class=\"flex-1 order-1 md:order-2\" data-kid=\"125\">\n        <div class=\"w-full aspect-square blob-mask bg-[var(--soft-blossom)]/5 p-8 md:p-16 flex items-center justify-center\" data-kid=\"126\">\n          <div class=\"w-full h-full bg-white blob-mask-alt shadow-2xl overflow-hidden\" data-kid=\"127\">\n            <img src=\"https://images.pexels.com/photos/1457801/pexels-photo-1457801.jpeg?auto=format&w=1200&q=80\" class=\"w-full h-full object-cover\" alt=\"Signature Match\" data-kid=\"128\">\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"129\">\n      <div class=\"flex items-center gap-8 group cursor-pointer\" data-kid=\"130\">\n        <div class=\"w-32 h-32 md:w-48 md:h-48 rounded-2xl overflow-hidden bg-[var(--ghost-white)] flex-shrink-0\" data-kid=\"131\">\n          <img src=\"https://images.pexels.com/photos/265856/pexels-photo-265856.jpeg?auto=format&w=400&q=80\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" alt=\"The Echo Loop\" data-kid=\"132\">\n        </div>\n        <div data-kid=\"133\">\n          <h4 class=\"text-2xl font-fraunces italic\" data-kid=\"134\">The Echo Loop</h4>\n          <p class=\"text-[10px] opacity-40 uppercase tracking-widest mt-2\" data-kid=\"135\">$3,200 &bull; 14k White Gold</p>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-8 group cursor-pointer\" data-kid=\"136\">\n        <div class=\"w-32 h-32 md:w-48 md:h-48 rounded-2xl overflow-hidden bg-[var(--ghost-white)] flex-shrink-0\" data-kid=\"137\">\n          <img src=\"https://images.pexels.com/photos/2849742/pexels-photo-2849742.jpeg?auto=format&w=400&q=80\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" alt=\"Gravity Drop\" data-kid=\"138\">\n        </div>\n        <div data-kid=\"139\">\n          <h4 class=\"text-2xl font-fraunces italic\" data-kid=\"140\">Gravity Drop</h4>\n          <p class=\"text-[10px] opacity-40 uppercase tracking-widest mt-2\" data-kid=\"141\">$1,150 &bull; Yellow Gold</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section id=\"ai-stylist\" class=\"flex flex-col md:flex-row min-h-[80vh] bg-[var(--ghost-white)]\" data-kid=\"142\">\n    \n    <div class=\"md:w-1/2 flex items-center justify-center p-12 md:p-24 text-center border-r border-[var(--carbon-black)]/5\" data-kid=\"143\">\n      <div class=\"max-w-md\" data-kid=\"144\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/diamond-ring.svg\" class=\"w-48 h-48 mx-auto mb-12 opacity-40\" style=\"filter: brightness(0) saturate(100%) invert(86%) sepia(16%) font-weight: 34% saturate(913%) hue-rotate(301deg) brightness(97%) contrast(96%);\" data-kid=\"145\">\n        <h2 class=\"text-5xl md:text-6xl font-fraunces text-[var(--carbon-black)] leading-tight mb-6\" data-kid=\"146\">Define Your <span class=\"italic text-[var(--soft-blossom)]\" data-kid=\"147\">Digital Soul</span></h2>\n        <p class=\"text-sm md:text-base font-dmsans opacity-50\" data-kid=\"148\">Our AI Stylist goes beyond trends, analyzing your lifestyle to suggest pieces that reflect your inner state.</p>\n      </div>\n    </div>\n\n    \n    <div class=\"md:w-1/2 bg-white flex flex-col justify-center px-8 md:px-24 py-16 md:py-32\" data-kid=\"149\">\n      <div class=\"mb-12\" data-kid=\"150\">\n        <div class=\"flex gap-2 mb-6\" data-kid=\"151\">\n          <div class=\"h-1 flex-1 bg-[var(--carbon-black)] rounded-full\" data-kid=\"152\"></div>\n          <div class=\"h-1 flex-1 bg-[var(--carbon-black)]/10 rounded-full\" data-kid=\"153\"></div>\n          <div class=\"h-1 flex-1 bg-[var(--carbon-black)]/10 rounded-full\" data-kid=\"154\"></div>\n          <div class=\"h-1 flex-1 bg-[var(--carbon-black)]/10 rounded-full\" data-kid=\"155\"></div>\n        </div>\n        <span class=\"text-[10px] uppercase tracking-[0.4em] opacity-40 block mb-4\" data-kid=\"156\">Phase 01 &mdash; Silhouette</span>\n        <h3 class=\"text-4xl font-fraunces text-[var(--carbon-black)] tracking-tight\" data-kid=\"157\">How do you envision your daily adornment?</h3>\n      </div>\n\n      <form class=\"space-y-4\" data-kid=\"158\">\n        <label class=\"block cursor-pointer group\" data-kid=\"159\">\n          <input type=\"radio\" name=\"silhouette\" class=\"hidden quiz-radio\" checked data-kid=\"160\">\n          <div class=\"p-6 border border-[var(--carbon-black)]/5 rounded-xl transition-all duration-300 hover:border-[var(--carbon-black)]/20\" data-kid=\"161\">\n            <div class=\"flex items-center justify-between\" data-kid=\"162\">\n              <div data-kid=\"163\">\n                <span class=\"block text-lg font-fraunces mb-1\" data-kid=\"164\">Architectural Minimalist</span>\n                <span class=\"block text-[11px] opacity-40 font-dmsans uppercase tracking-widest\" data-kid=\"165\">Bold volumes, clean edges.</span>\n              </div>\n              <div class=\"w-6 h-6 rounded-full border border-[var(--carbon-black)]/10 flex items-center justify-center radio-circle\" data-kid=\"166\">\n                <div class=\"w-2.5 h-2.5 rounded-full bg-white\" data-kid=\"167\"></div>\n              </div>\n            </div>\n          </div>\n        </label>\n\n        <label class=\"block cursor-pointer group\" data-kid=\"168\">\n          <input type=\"radio\" name=\"silhouette\" class=\"hidden quiz-radio\" data-kid=\"169\">\n          <div class=\"p-8 border border-[var(--carbon-black)]/5 rounded-[2rem] transition-all hover:bg-white group-hover:border-[var(--carbon-black)]/20\" data-kid=\"170\">\n            <div class=\"flex items-center justify-between\" data-kid=\"171\">\n              <div data-kid=\"172\">\n                <span class=\"block text-xl font-fraunces mb-1\" data-kid=\"173\">Ethereal Romantic</span>\n                <span class=\"block text-sm opacity-50 font-dmsans\" data-kid=\"174\">Delicate filigree, organic shapes, soft curves.</span>\n              </div>\n              <div class=\"w-8 h-8 rounded-full border-2 border-[var(--carbon-black)]/10 flex items-center justify-center radio-circle\" data-kid=\"175\">\n                <div class=\"w-3 h-3 rounded-full bg-white\" data-kid=\"176\"></div>\n              </div>\n            </div>\n          </div>\n        </label>\n\n        <label class=\"block cursor-pointer group\" data-kid=\"177\">\n          <input type=\"radio\" name=\"silhouette\" class=\"hidden quiz-radio\" data-kid=\"178\">\n          <div class=\"p-8 border border-[var(--carbon-black)]/5 rounded-[2rem] transition-all hover:bg-white group-hover:border-[var(--carbon-black)]/20\" data-kid=\"179\">\n            <div class=\"flex items-center justify-between\" data-kid=\"180\">\n              <div data-kid=\"181\">\n                <span class=\"block text-xl font-fraunces mb-1\" data-kid=\"182\">Avante-Garde Sculptural</span>\n                <span class=\"block text-sm opacity-50 font-dmsans\" data-kid=\"183\">Asymmetric forms, mixed metals, conversation pieces.</span>\n              </div>\n              <div class=\"w-8 h-8 rounded-full border-2 border-[var(--carbon-black)]/10 flex items-center justify-center radio-circle\" data-kid=\"184\">\n                <div class=\"w-3 h-3 rounded-full bg-white\" data-kid=\"185\"></div>\n              </div>\n            </div>\n          </div>\n        </label>\n      </form>\n\n      <div class=\"mt-16 flex justify-between items-center\" data-kid=\"186\">\n        <button class=\"text-[10px] uppercase tracking-[0.4em] opacity-40 hover:opacity-100 transition-opacity\" data-kid=\"187\">Skip Analysis</button>\n        <button type=\"button\" class=\"bg-[var(--carbon-black)] text-white px-12 py-5 rounded-full text-xs uppercase tracking-[0.4em] shadow-lg hover:bg-[var(--soft-blossom)] hover:text-[var(--carbon-black)] transition-all duration-500\" data-kid=\"188\">\n          Next Phase\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 md:py-32 bg-[var(--ghost-white)] px-8 md:px-16\" data-kid=\"189\">\n    <div class=\"max-w-4xl mx-auto space-y-24\" data-kid=\"190\">\n      \n      <div class=\"relative\" data-kid=\"191\">\n        <span class=\"absolute -left-8 md:-left-12 top-0 text-6xl md:text-8xl font-fraunces text-[var(--soft-blossom)]/30 opacity-50 italic\" data-kid=\"192\">“</span>\n        <blockquote class=\"text-3xl md:text-5xl font-fraunces leading-[1.15] mb-8\" data-kid=\"193\">\n          The AI match was eerily accurate. I've never felt so seen by an algorithm—my 'Neural Band' is now an extension of my identity.\n        </blockquote>\n        <div class=\"flex items-center gap-4\" data-kid=\"194\">\n          <div class=\"w-10 h-10 rounded-full overflow-hidden bg-[var(--soft-blossom)]/20\" data-kid=\"195\">\n            <img src=\"https://i.pravatar.cc/100?u=a\" alt=\"Elena Vance\" class=\"w-full h-full object-cover\" data-kid=\"196\">\n          </div>\n          <div data-kid=\"197\">\n            <p class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"198\">Elena Vance</p>\n            <p class=\"text-[9px] opacity-40 uppercase tracking-widest\" data-kid=\"199\">Verified Collector</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative pl-12 md:pl-24\" data-kid=\"200\">\n        <span class=\"absolute -left-2 md:left-12 top-0 text-6xl md:text-8xl font-fraunces text-[var(--soft-blossom)]/30 opacity-50 italic\" data-kid=\"201\">“</span>\n        <blockquote class=\"text-3xl md:text-5xl font-fraunces leading-[1.15] mb-8\" data-kid=\"202\">\n          Minimalist luxury redefined. The shopping experience was as fluid as the gold curves of the pieces themselves.\n        </blockquote>\n        <div class=\"flex items-center gap-4\" data-kid=\"203\">\n          <div class=\"w-10 h-10 rounded-full overflow-hidden bg-[var(--soft-blossom)]/20\" data-kid=\"204\">\n            <img src=\"https://i.pravatar.cc/100?u=b\" alt=\"Marcus Chen\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" data-kid=\"205\">\n          </div>\n          <div data-kid=\"206\">\n            <p class=\"text-[10px] font-bold uppercase tracking-widest\" data-kid=\"207\">Marcus Chen</p>\n            <p class=\"text-[9px] opacity-40 uppercase tracking-widest\" data-kid=\"208\">Creative Director</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"bg-white px-8 md:px-16 pt-24 md:pt-32 pb-12 border-t border-[var(--carbon-black)]/5\" data-kid=\"209\">\n    <div class=\"bg-[var(--ghost-white)] rounded-[2.5rem] p-12 md:p-24 text-center mb-24 relative overflow-hidden group\" data-kid=\"210\">\n      <div class=\"relative z-10\" data-kid=\"211\">\n        <h2 class=\"text-5xl md:text-8xl font-fraunces mb-8 leading-[0.9]\" data-kid=\"212\">Your <span class=\"italic\" data-kid=\"213\">Masterpiece</span> <br data-kid=\"214\">Awaits.</h2>\n        <div class=\"flex flex-col md:flex-row gap-4 justify-center\" data-kid=\"215\">\n          <button class=\"bg-[var(--carbon-black)] text-white px-10 py-5 rounded-full text-[10px] uppercase tracking-widest hover:bg-[var(--soft-blossom)] hover:text-[var(--carbon-black)] transition-all duration-300\" data-kid=\"216\">Consult AI Stylist</button>\n          <button class=\"bg-white border border-[var(--carbon-black)]/10 px-10 py-5 rounded-full text-[10px] uppercase tracking-widest hover:border-[var(--carbon-black)] transition-all duration-300\" data-kid=\"217\">Request Catalog</button>\n        </div>\n      </div>\n      \n      <div class=\"absolute -top-12 -left-12 w-64 h-64 blob-mask bg-[var(--soft-blossom)]/10 group-hover:scale-110 transition-transform duration-1000\" data-kid=\"218\"></div>\n    </div>\n\n    <div class=\"grid grid-cols-2 md:grid-cols-4 gap-12 border-b border-[var(--carbon-black)]/5 pb-16\" data-kid=\"219\">\n      <div class=\"col-span-2 md:col-span-1\" data-kid=\"220\">\n        <div class=\"text-3xl font-fraunces font-bold italic mb-8\" data-kid=\"221\">Luma</div>\n        <p class=\"text-sm opacity-50 leading-relaxed mb-8\" data-kid=\"222\">The first luxury jewellery house to merge artificial intelligence with master craftsmanship. Designed for the digital era.</p>\n        <div class=\"flex gap-6\" data-kid=\"223\">\n          <i class=\"ti ti-brand-instagram text-2xl opacity-40 hover:opacity-100 transition-opacity cursor-pointer\" data-kid=\"224\"></i>\n          <i class=\"ti ti-brand-twitter text-2xl opacity-40 hover:opacity-100 transition-opacity cursor-pointer\" data-kid=\"225\"></i>\n          <i class=\"ti ti-brand-linkedin text-2xl opacity-40 hover:opacity-100 transition-opacity cursor-pointer\" data-kid=\"226\"></i>\n        </div>\n      </div>\n      <div data-kid=\"227\">\n        <h5 class=\"text-xs uppercase tracking-[0.3em] font-bold mb-8\" data-kid=\"228\">Collections</h5>\n        <ul class=\"space-y-4 text-sm opacity-50\" data-kid=\"229\">\n          <li data-kid=\"230\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"231\">Neural Bands</a></li>\n          <li data-kid=\"232\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"233\">Digital Flora</a></li>\n          <li data-kid=\"234\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"235\">Prism Core</a></li>\n          <li data-kid=\"236\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"237\">Bespoke Requests</a></li>\n        </ul>\n      </div>\n      <div data-kid=\"238\">\n        <h5 class=\"text-xs uppercase tracking-[0.3em] font-bold mb-8\" data-kid=\"239\">Intelligence</h5>\n        <ul class=\"space-y-4 text-sm opacity-50\" data-kid=\"240\">\n          <li data-kid=\"241\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"242\">Aesthetic Engine</a></li>\n          <li data-kid=\"243\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"244\">Virtual Try-On</a></li>\n          <li data-kid=\"245\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"246\">Personal Stylist</a></li>\n          <li data-kid=\"247\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"248\">Style Blueprint</a></li>\n        </ul>\n      </div>\n      <div data-kid=\"249\">\n        <h5 class=\"text-xs uppercase tracking-[0.3em] font-bold mb-8\" data-kid=\"250\">Maison</h5>\n        <ul class=\"space-y-4 text-sm opacity-50\" data-kid=\"251\">\n          <li data-kid=\"252\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"253\">Our Craft</a></li>\n          <li data-kid=\"254\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"255\">Sustainability</a></li>\n          <li data-kid=\"256\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"257\">Press Inquiry</a></li>\n          <li data-kid=\"258\"><a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"259\">Global Boutiques</a></li>\n        </ul>\n      </div>\n    </div>\n\n    <div class=\"flex flex-col md:flex-row justify-between items-center pt-12 text-[10px] uppercase tracking-[0.3em] opacity-30\" data-kid=\"260\">\n      <p data-kid=\"261\">&copy; 2024 LumaJewels AI. All Rights Reserved.</p>\n      <div class=\"flex gap-12 mt-6 md:mt-0\" data-kid=\"262\">\n        <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"263\">Privacy Policy</a>\n        <a href=\"#\" class=\"hover:opacity-100 transition-opacity\" data-kid=\"264\">Terms of Service</a>\n      </div>\n    </div>\n  </footer>\n</main>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"265\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"266\"></script>\n<script type=\"module\" data-kid=\"267\">\n  import { animate, stagger, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import Lenis from \"https://esm.sh/lenis@1\"\n  import Snap from \"https://esm.sh/lenis@1/snap\"\n\n  // Initialize Lenis for smooth scroll\n  const lenis = new Lenis({\n    lerp: 0.1,\n    wheelMultiplier: 1.2,\n    gestureOrientation: 'vertical',\n    normalizeWheel: true,\n    smoothWheel: true,\n  });\n\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Marquee Animation (Anime.js/GSAP logic)\n  gsap.to(\".marquee-track\", {\n    xPercent: -50,\n    ease: \"none\",\n    duration: 30,\n    repeat: -1,\n  });\n\n  // Hero Cards Stagger - Ensure no FOUC by setting initial state via GSAP if needed, \n  // but gsap.from already handles hiding until the tween starts if autoAlpha is used or by default.\n  // However, since opacity:0 was removed from CSS, we ensure they start from invisible here.\n  gsap.from(\".stagger-card\", {\n    opacity: 0,\n    y: 60,\n    duration: 1.2,\n    stagger: 0.15,\n    ease: \"expo.out\",\n    delay: 0.2\n  });\n\n  // Reveal animations on scroll\n  const revealElements = document.querySelectorAll(\".blob-mask, .blob-mask-alt\");\n  revealElements.forEach(el => {\n    gsap.from(el, {\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 90%\",\n      },\n      scale: 0.8,\n      opacity: 0,\n      duration: 1.2,\n      ease: \"power3.out\"\n    });\n  });\n\n  // Carousel navigation\n  const carousel = document.querySelector('.carousel-track');\n  document.querySelector('.carousel-next').addEventListener('click', () => {\n    carousel.scrollBy({ left: 550, behavior: 'smooth' });\n  });\n  document.querySelector('.carousel-prev').addEventListener('click', () => {\n    carousel.scrollBy({ left: -550, behavior: 'smooth' });\n  });\n\n</script>\n",
