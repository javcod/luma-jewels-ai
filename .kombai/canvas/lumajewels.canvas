      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Source+Serif+4:wght@300;400;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css');\n\n    :root {\n        --color-beige: #F5F5DC;\n        --color-gold: #D4AF37;\n        --color-charcoal: #36454F;\n    }\n\n    body {\n        background-color: var(--color-beige);\n        color: var(--color-charcoal);\n        font-family: 'Source Serif 4', serif;\n        margin: 0;\n        overflow-x: clip;\n    }\n\n    h1, h2, h3, h4, h5, h6, .font-display {\n        font-family: 'Playfair Display', serif;\n    }\n\n    @keyframes spin-slow {\n        from { transform: rotate(0deg); }\n        to { transform: rotate(360deg); }\n    }\n    .animate-spin-slow {\n        animation: spin-slow 12s linear infinite;\n    }\n    .diagonal-radius {\n        border-radius: 80px 0 80px 0;\n    }\n\n    .gold-accent {\n        border: 1.5px solid #d4a843;\n    }\n\n    /* Custom Scrollbar for Carousel */\n    .no-scrollbar::-webkit-scrollbar {\n        display: none;\n    }\n    .no-scrollbar {\n        -ms-overflow-style: none;\n        scrollbar-width: none;\n    }\n\n    /* Locomotive/Lenis required CSS */\n    html.lenis, html.lenis body {\n      height: auto;\n    }\n    .lenis.lenis-smooth {\n      scroll-behavior: auto !important;\n    }\n    .lenis.lenis-smooth [data-lenis-prevent] {\n      overscroll-behavior: contain;\n    }\n    .lenis.lenis-stopped {\n      overflow: hidden;\n    }\n    .lenis.lenis-scrolling iframe {\n      pointer-events: none;\n    }\n</style>\n\n\n<nav class=\"fixed top-0 left-0 w-full z-50 px-8 py-4 flex justify-between items-center pointer-events-none transition-all duration-500\" id=\"main-nav\" data-kid=\"1\">\n    <div class=\"pointer-events-auto\" data-kid=\"2\">\n        <a href=\"#\" class=\"text-[var(--color-charcoal)] text-xl font-display tracking-tighter italic bg-white/80 backdrop-blur-md px-4 py-2 rounded-full border border-[var(--color-gold)]/20 shadow-sm\" data-kid=\"3\">LumaJewels<span class=\"not-italic font-bold\" data-kid=\"4\">AI</span></a>\n    </div>\n    <div class=\"hidden md:flex gap-10 pointer-events-auto bg-white/80 backdrop-blur-md px-8 py-3 rounded-full border border-[var(--color-gold)]/20 shadow-sm\" data-kid=\"5\">\n        <a href=\"#collections\" class=\"text-[var(--color-charcoal)] text-xs font-bold uppercase tracking-widest hover:text-[var(--color-gold)] transition-colors\" data-kid=\"6\">Collections</a>\n        <a href=\"#ai-match\" class=\"text-[var(--color-charcoal)] text-xs font-bold uppercase tracking-widest hover:text-[var(--color-gold)] transition-colors\" data-kid=\"7\">AI Match</a>\n        <a href=\"#quiz\" class=\"text-[var(--color-charcoal)] text-xs font-bold uppercase tracking-widest hover:text-[var(--color-gold)] transition-colors\" data-kid=\"8\">Style Quiz</a>\n    </div>\n    <div class=\"pointer-events-auto\" data-kid=\"9\">\n        <button class=\"bg-[var(--color-charcoal)] text-white px-6 py-3 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-[var(--color-gold)] transition-all shadow-lg shadow-black/10\" data-kid=\"10\">Bespoke Curation</button>\n    </div>\n</nav>\n\n<main data-kid=\"11\">\n    \n    <section id=\"hero\" class=\"relative min-h-screen flex flex-col justify-end overflow-hidden\" data-kid=\"12\">\n        \n        <div class=\"absolute inset-0 z-0\" data-kid=\"13\">\n            <div data-scroll data-scroll-speed=\"-6\" class=\"w-full h-full\" data-kid=\"14\">\n                <img src=\"https://images.unsplash.com/photo-1733322980520-f9463b596a58?auto=format&w=1600&q=80&fit=crop\" alt=\"Cinematic Model\" class=\"w-full h-[150%] object-cover object-center brightness-90 grayscale-[10%]\" decoding=\"async\" loading=\"lazy\" data-kid=\"15\">\n            </div>\n        </div>\n        \n        \n        <div class=\"relative z-10 w-full px-4 md:px-12 pb-12 md:pb-24 flex justify-start\" data-kid=\"16\">\n            <div class=\"bg-[var(--color-beige)] p-8 md:p-20 diagonal-radius shadow-2xl border-t border-l border-[var(--color-gold)]/30 max-w-5xl\" data-scroll data-scroll-speed=\"1.5\" data-kid=\"17\">\n                <div class=\"flex items-center gap-6 mb-8\" data-kid=\"18\">\n                    <div class=\"w-12 h-12 rounded-full border border-[var(--color-gold)] flex items-center justify-center animate-spin-slow\" data-kid=\"19\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--color-gold)\" stroke-width=\"1.5\" data-kid=\"20\"><path d=\"M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48 2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48 2.83-2.83\" data-kid=\"21\"></path></svg>\n                    </div>\n                    <span class=\"text-[var(--color-gold)] font-bold uppercase tracking-[0.5em] text-xs\" data-kid=\"22\">AI-Enhanced Legacy Selection</span>\n                </div>\n                <h1 class=\"text-5xl md:text-9xl text-[var(--color-charcoal)] leading-[0.85] mb-10 font-display\" data-kid=\"23\">\n                    Defining the <br data-kid=\"24\"><span class=\"italic font-normal\" data-kid=\"25\">Modern</span> Heirloom\n                </h1>\n                <p class=\"text-xl md:text-2xl text-[var(--color-charcoal)] max-w-2xl mb-12 leading-relaxed font-light\" data-kid=\"26\">\n                    Where mid-century craftsmanship meets neural precision. Personalized matching for your singular silhouette.\n                </p>\n                <div class=\"flex flex-wrap gap-8 items-center\" data-kid=\"27\">\n                    <button class=\"bg-[var(--color-charcoal)] text-white px-12 py-6 rounded-full font-bold hover:bg-[var(--color-gold)] transition-all duration-700 flex items-center gap-4 group shadow-[0_20px_40px_rgba(0,0,0,0.15)]\" data-kid=\"28\">\n                        Explore Collections\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"group-hover:translate-x-2 transition-transform\" data-kid=\"29\"><path d=\"M5 12h14m-7-7 7 7-7 7\" data-kid=\"30\"></path></svg>\n                    </button>\n                    <div class=\"flex items-center gap-6 py-4 px-6 border border-[var(--color-gold)]/20 rounded-full\" data-kid=\"31\">\n                        <span class=\"w-2 h-2 rounded-full bg-[var(--color-gold)] animate-pulse\" data-kid=\"32\"></span>\n                        <span class=\"text-sm font-bold uppercase tracking-widest text-[var(--color-charcoal)]/80\" data-kid=\"33\">98.4% Match Accuracy</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"collections\" class=\"bg-[var(--color-beige)] py-24 md:py-48 overflow-hidden\" data-kid=\"34\">\n        <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"35\">\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-24 items-center mb-32 md:mb-64\" data-kid=\"36\">\n                <div class=\"md:col-span-7 relative\" data-kid=\"37\">\n                    <div class=\"relative z-10 overflow-hidden rounded-[120px_0_120px_0] shadow-2xl\" data-kid=\"38\">\n                        <div data-scroll data-scroll-speed=\"-0.5\" data-kid=\"39\">\n                            <img src=\"https://images.unsplash.com/photo-1633815475737-11cf50445bef?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover aspect-[4/5] hover:scale-105 transition-transform duration-[2000ms]\" alt=\"Series One\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n                        </div>\n                    </div>\n                    <div class=\"absolute -bottom-16 -right-16 w-64 h-64 bg-[var(--color-gold)]/10 rounded-full blur-[80px] -z-0\" data-kid=\"41\"></div>\n                </div>\n                <div class=\"md:col-span-5 md:pl-12\" data-kid=\"42\">\n                    <span class=\"text-[var(--color-gold)] text-sm font-bold tracking-[0.5em] uppercase mb-8 block\" data-kid=\"43\">Series 01 / Radiance</span>\n                    <h2 class=\"text-6xl md:text-8xl text-[var(--color-charcoal)] mb-8 leading-tight font-display\" data-kid=\"44\">Structural <br data-kid=\"45\"><span class=\"italic font-normal\" data-kid=\"46\">Grace</span></h2>\n                    <p class=\"text-xl text-[var(--color-charcoal)] mb-12 leading-relaxed max-w-md\" data-kid=\"47\">\n                        Inspired by architectural minimalism. Our AI identifies the optimal width and weight for your profile, ensuring each piece complements your natural silhouette.\n                    </p>\n                    <a href=\"#\" class=\"inline-flex items-center gap-6 text-[var(--color-charcoal)] font-bold group bg-white/50 backdrop-blur-md px-8 py-4 rounded-full border border-[var(--color-gold)]/20 shadow-sm hover:shadow-md transition-all\" data-kid=\"48\">\n                        <span class=\"border-b-2 border-[var(--color-gold)] pb-1\" data-kid=\"49\">Bespoke Curation</span>\n                        <div class=\"w-10 h-10 rounded-full border border-[var(--color-gold)] flex items-center justify-center group-hover:bg-[var(--color-gold)] group-hover:text-white transition-all\" data-kid=\"50\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"51\"><path d=\"M5 12h14m-7-7 7 7-7 7\" data-kid=\"52\"></path></svg>\n                        </div>\n                    </a>\n                </div>\n            </div>\n\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-24 items-center\" data-kid=\"53\">\n                <div class=\"md:col-span-5 order-2 md:order-1 md:pr-12\" data-kid=\"54\">\n                    <span class=\"text-[var(--color-gold)] text-sm font-bold tracking-[0.5em] uppercase mb-8 block\" data-kid=\"55\">Series 02 / Luminous</span>\n                    <h2 class=\"text-6xl md:text-8xl text-[var(--color-charcoal)] mb-8 leading-tight font-display\" data-kid=\"56\">Neural <br data-kid=\"57\"><span class=\"italic font-normal\" data-kid=\"58\">Optics</span></h2>\n                    <p class=\"text-xl text-[var(--color-charcoal)] mb-12 leading-relaxed max-w-md\" data-kid=\"59\">\n                        A dialogue between light and synthetic precision. Using neural rendering to predict brilliance in every environment—from gala moonlight to daylight galas.\n                    </p>\n                    <a href=\"#\" class=\"inline-flex items-center gap-6 text-[var(--color-charcoal)] font-bold group bg-[var(--color-charcoal)] text-white px-10 py-5 rounded-full shadow-xl hover:bg-[var(--color-gold)] transition-all\" data-kid=\"60\">\n                        <span data-kid=\"61\">The Lookbook</span>\n                        <div class=\"w-8 h-[2px] bg-white group-hover:w-12 transition-all\" data-kid=\"62\"></div>\n                    </a>\n                </div>\n                <div class=\"md:col-span-7 order-1 md:order-2 relative\" data-kid=\"63\">\n                    <div class=\"relative z-10 overflow-hidden rounded-[0_120px_0_120px] shadow-2xl\" data-kid=\"64\">\n                        <div data-scroll data-scroll-speed=\"0.5\" data-kid=\"65\">\n                            <img src=\"https://images.unsplash.com/photo-1648058763081-5244817f7d9e?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover aspect-[4/5] hover:scale-105 transition-transform duration-[2000ms]\" alt=\"Series Two\" decoding=\"async\" loading=\"lazy\" data-kid=\"66\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"ai-match\" class=\"py-32 md:py-64 bg-[var(--color-beige)] relative overflow-hidden\" data-kid=\"67\">\n        <div class=\"max-w-7xl mx-auto px-6 mb-24 flex flex-col items-center text-center\" data-kid=\"68\">\n            <span class=\"text-[var(--color-gold)] font-bold uppercase tracking-[0.4em] text-xs mb-8 block\" data-kid=\"69\">Bespoke Curation Engine</span>\n            <h2 class=\"text-5xl md:text-9xl text-[var(--color-charcoal)] mb-12 font-display\" data-kid=\"70\">Synthetic <br data-kid=\"71\"><span class=\"italic font-normal\" data-kid=\"72\">Essentials</span></h2>\n            <div class=\"w-px h-24 bg-[var(--color-gold)] mb-12\" data-kid=\"73\"></div>\n        </div>\n\n        <div class=\"max-w-[1440px] mx-auto px-6\" data-kid=\"74\">\n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-8 items-start\" data-kid=\"75\">\n                \n                <div class=\"md:col-span-5 group\" data-kid=\"76\">\n                    <div class=\"relative overflow-hidden aspect-[3/4] rounded-[80px_0_80px_0] gold-accent mb-8 shadow-2xl\" data-kid=\"77\">\n                        <img src=\"https://images.unsplash.com/photo-1753268521791-d77a9a3787b0?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover transition-transform duration-[2000ms] group-hover:scale-110\" alt=\"Drop Earrings\" decoding=\"async\" loading=\"lazy\" data-kid=\"78\">\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-charcoal)] via-transparent to-transparent opacity-0 group-hover:opacity-90 transition-opacity flex flex-col justify-end p-12\" data-kid=\"79\">\n                            <div class=\"translate-y-8 group-hover:translate-y-0 transition-transform duration-700\" data-kid=\"80\">\n                                <span class=\"text-[var(--color-gold)] text-xs font-bold uppercase tracking-widest mb-4 block\" data-kid=\"81\">Neural Pairing 98.4%</span>\n                                <p class=\"text-white text-xl italic font-display\" data-kid=\"82\">\"An asymmetric drop that captures ambient light precisely at your ear level.\"</p>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"flex justify-between items-end\" data-kid=\"83\">\n                        <div data-kid=\"84\">\n                            <h3 class=\"text-4xl text-[var(--color-charcoal)] mb-2 font-display\" data-kid=\"85\">Gilded Drops</h3>\n                            <p class=\"text-[var(--color-gold)] font-bold tracking-widest uppercase text-sm\" data-kid=\"86\">Series 01 / $2,450</p>\n                        </div>\n                        <button class=\"w-16 h-16 rounded-full border border-[var(--color-gold)] flex items-center justify-center hover:bg-[var(--color-charcoal)] hover:text-white transition-all\" data-kid=\"87\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"88\"><path d=\"M5 12h14m-7-7 7 7-7 7\" data-kid=\"89\"></path></svg>\n                        </button>\n                    </div>\n                </div>\n\n                \n                <div class=\"md:col-span-4 md:mt-32 group\" data-kid=\"90\">\n                    <div class=\"relative overflow-hidden aspect-[4/5] rounded-[0_60px_0_60px] gold-accent mb-8 shadow-2xl\" data-kid=\"91\">\n                        <img src=\"https://images.pexels.com/photos/34052045/pexels-photo-34052045.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover transition-transform duration-[2000ms] group-hover:scale-110\" alt=\"Choker\" decoding=\"async\" loading=\"lazy\" data-kid=\"92\">\n                    </div>\n                    <div data-kid=\"93\">\n                        <h3 class=\"text-3xl text-[var(--color-charcoal)] mb-2 font-display\" data-kid=\"94\">Crimson Flare</h3>\n                        <p class=\"text-[var(--color-gold)] font-bold tracking-widest uppercase text-sm\" data-kid=\"95\">Series 02 / $4,200</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"md:col-span-3 md:mt-16 group\" data-kid=\"96\">\n                    <div class=\"relative overflow-hidden aspect-square rounded-full gold-accent mb-8 shadow-2xl\" data-kid=\"97\">\n                        <img src=\"https://images.pexels.com/photos/33055710/pexels-photo-33055710.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover transition-transform duration-[2000ms] group-hover:scale-110\" alt=\"Cuff\" decoding=\"async\" loading=\"lazy\" data-kid=\"98\">\n                    </div>\n                    <div data-kid=\"99\">\n                        <h3 class=\"text-2xl text-[var(--color-charcoal)] mb-1 font-display\" data-kid=\"100\">Architectural Cuff</h3>\n                        <p class=\"text-[var(--color-gold)] font-bold tracking-widest uppercase text-xs\" data-kid=\"101\">Accessory / $1,850</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 md:py-64 bg-[var(--color-beige)] relative overflow-hidden\" data-kid=\"102\">\n        <div class=\"max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-32\" data-kid=\"103\">\n            <div class=\"md:col-span-8\" data-kid=\"104\">\n                <div class=\"mb-32\" data-kid=\"105\">\n                    <h2 class=\"text-6xl md:text-9xl text-[var(--color-charcoal)] mb-12 font-display leading-[0.85]\" data-kid=\"106\">Purity in <br data-kid=\"107\"><span class=\"italic font-normal\" data-kid=\"108\">Process</span></h2>\n                    <p class=\"text-2xl md:text-3xl text-[var(--color-charcoal)] leading-relaxed font-light border-l-4 border-[var(--color-gold)] pl-12 max-w-2xl\" data-kid=\"109\">\n                        Where the computational meets the corporeal. Every curve is calculated, every stone is verified, and every piece is unique.\n                    </p>\n                </div>\n                \n                <div class=\"grid grid-cols-1 md:grid-cols-2 gap-24\" data-kid=\"110\">\n                    <div class=\"group\" data-kid=\"111\">\n                        <div class=\"w-px h-16 bg-[var(--color-gold)] mb-8\" data-kid=\"112\"></div>\n                        <h4 class=\"text-3xl text-[var(--color-charcoal)] mb-6 font-display\" data-kid=\"113\">Neural Mapping</h4>\n                        <p class=\"text-lg text-[var(--color-charcoal)] leading-relaxed\" data-kid=\"114\">\n                            A deep-learning analysis of ten millennia of jewelry tradition ensures that your piece adheres to universal laws of beauty and balance.\n                        </p>\n                    </div>\n\n                    <div class=\"group\" data-kid=\"115\">\n                        <div class=\"w-px h-16 bg-[var(--color-gold)] mb-8\" data-kid=\"116\"></div>\n                        <h4 class=\"text-3xl text-[var(--color-charcoal)] mb-6 font-display\" data-kid=\"117\">Block Verification</h4>\n                        <p class=\"text-lg text-[var(--color-charcoal)] leading-relaxed\" data-kid=\"118\">\n                            Absolute provenance. Our proprietary AI monitors the entire supply chain to guarantee ethical sourcing and conflict-free diamonds.\n                        </p>\n                    </div>\n\n                    <div class=\"group md:col-span-2\" data-kid=\"119\">\n                        <div class=\"w-px h-16 bg-[var(--color-gold)] mb-8\" data-kid=\"120\"></div>\n                        <h4 class=\"text-3xl text-[var(--color-charcoal)] mb-6 font-display\" data-kid=\"121\">Bespoke Precision</h4>\n                        <p class=\"text-lg text-[var(--color-charcoal)] leading-relaxed max-w-2xl\" data-kid=\"122\">\n                            We combine algorithmic perfect with the soul of hand-finishings. The result is a masterpiece of precision that retains the warmth of the artisan's touch.\n                        </p>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"md:col-span-4 relative\" data-kid=\"123\">\n                <div class=\"sticky top-32 space-y-12\" data-kid=\"124\">\n                    <div class=\"relative pl-12\" data-kid=\"125\">\n                        <div class=\"absolute left-0 top-0 w-px h-full bg-gradient-to-b from-[var(--color-gold)] to-transparent\" data-kid=\"126\"></div>\n                        <p class=\"text-[var(--color-charcoal)] italic text-xl mb-6\" data-kid=\"127\">\"The precision is terrifyingly beautiful. I've never seen such a perfect marriage of code and craft.\"</p>\n                        <span class=\"text-[var(--color-gold)] font-bold text-xs tracking-widest uppercase\" data-kid=\"128\">— High Fashion Quarterly</span>\n                    </div>\n\n                    <div class=\"relative pl-12\" data-kid=\"129\">\n                        <div class=\"absolute left-0 top-0 w-px h-full bg-gradient-to-b from-[var(--color-gold)] to-transparent\" data-kid=\"130\"></div>\n                        <p class=\"text-[var(--color-charcoal)] italic text-xl mb-6\" data-kid=\"131\">\"A new standard for ethical luxury. LumaJewels is where the industry is heading.\"</p>\n                        <span class=\"text-[var(--color-gold)] font-bold text-xs tracking-widest uppercase\" data-kid=\"132\">— SustainaLux Guide</span>\n                    </div>\n                    \n                    <div class=\"bg-[var(--color-charcoal)] text-white p-12 rounded-[60px_0_60px_0] shadow-2xl\" data-kid=\"133\">\n                        <h5 class=\"text-3xl font-display mb-4\" data-kid=\"134\">12k+</h5>\n                        <p class=\"text-sm uppercase tracking-widest text-white/60 mb-8\" data-kid=\"135\">Global Clients</p>\n                        <div class=\"flex -space-x-4\" data-kid=\"136\">\n                            <img src=\"https://i.pravatar.cc/60?u=1\" class=\"w-12 h-12 rounded-full border-2 border-[var(--color-charcoal)]\" alt=\"U\" data-kid=\"137\">\n                            <img src=\"https://i.pravatar.cc/60?u=2\" class=\"w-12 h-12 rounded-full border-2 border-[var(--color-charcoal)]\" alt=\"U\" data-kid=\"138\">\n                            <img src=\"https://i.pravatar.cc/60?u=3\" class=\"w-12 h-12 rounded-full border-2 border-[var(--color-charcoal)]\" alt=\"U\" data-kid=\"139\">\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"quiz\" class=\"py-32 px-6 md:px-12 bg-[#EFEBE0] relative overflow-hidden\" data-kid=\"140\">\n        <div class=\"absolute top-0 left-0 w-full h-full pointer-events-none opacity-20\" data-kid=\"141\">\n            <div class=\"absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-[var(--color-gold)] blur-[120px]\" data-kid=\"142\"></div>\n            <div class=\"absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-[var(--color-charcoal)] blur-[120px]\" data-kid=\"143\"></div>\n        </div>\n\n        <div class=\"max-w-6xl mx-auto relative z-10\" data-kid=\"144\">\n            <div class=\"text-center mb-20\" data-scroll data-scroll-speed=\"0.5\" data-kid=\"145\">\n                <h2 class=\"text-5xl md:text-7xl text-[var(--color-charcoal)] mb-8\" data-kid=\"146\">Discover Your <br data-kid=\"147\"><span class=\"italic font-normal\" data-kid=\"148\">Aesthetic Signature</span></h2>\n                <p class=\"text-xl text-[var(--color-charcoal)]/60 max-w-2xl mx-auto\" data-kid=\"149\">Our visual wizard uses computer vision to interpret your taste. Simply select the imagery that speaks to your soul.</p>\n            </div>\n\n            <div class=\"bg-white/60 backdrop-blur-2xl diagonal-radius border border-[var(--color-gold)]/30 p-8 md:p-16 shadow-[0_50px_100px_-20px_rgba(0,0,0,0.1)] transform hover:scale-[1.01] transition-transform duration-700\" data-kid=\"150\">\n                \n                <div class=\"mb-16\" data-kid=\"151\">\n                    <div class=\"flex justify-between items-center mb-6\" data-kid=\"152\">\n                        <div class=\"flex gap-4\" data-kid=\"153\">\n                            <div class=\"w-3 h-3 rounded-full bg-[var(--color-gold)]\" data-kid=\"154\"></div>\n                            <div class=\"w-3 h-3 rounded-full bg-[var(--color-gold)]\" data-kid=\"155\"></div>\n                            <div class=\"w-3 h-3 rounded-full bg-[var(--color-gold)]/20\" data-kid=\"156\"></div>\n                            <div class=\"w-3 h-3 rounded-full bg-[var(--color-gold)]/20\" data-kid=\"157\"></div>\n                        </div>\n                        <span class=\"text-[var(--color-gold)] font-bold text-xs uppercase tracking-[0.3em]\" data-kid=\"158\">Step 02 / 04</span>\n                    </div>\n                    <div class=\"w-full h-[2px] bg-gray-100\" data-kid=\"159\">\n                        <div class=\"w-1/2 h-full bg-[var(--color-gold)]\" data-kid=\"160\"></div>\n                    </div>\n                </div>\n\n                <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 mb-16\" data-kid=\"161\">\n                    \n                    <button class=\"group relative overflow-hidden aspect-[3/4] rounded-3xl text-left focus:ring-4 focus:ring-[var(--color-gold)] outline-none transition-all\" data-kid=\"162\">\n                        <img src=\"https://images.pexels.com/photos/10719839/pexels-photo-10719839.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110\" alt=\"Option\" data-kid=\"163\">\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-charcoal)]/90 via-transparent to-transparent\" data-kid=\"164\"></div>\n                        <div class=\"absolute bottom-8 left-8 right-8\" data-kid=\"165\">\n                            <h4 class=\"text-2xl text-white mb-2\" data-kid=\"166\">Midnight Noir</h4>\n                            <p class=\"text-white/60 text-sm\" data-kid=\"167\">Dramatic, high-contrast silhouettes for gala evenings.</p>\n                        </div>\n                    </button>\n                    \n                    <button class=\"group relative overflow-hidden aspect-[3/4] rounded-3xl text-left ring-4 ring-[var(--color-gold)] outline-none transition-all\" data-kid=\"168\">\n                        <img src=\"https://images.pexels.com/photos/7905336/pexels-photo-7905336.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110\" alt=\"Option\" data-kid=\"169\">\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-charcoal)]/90 via-transparent to-transparent\" data-kid=\"170\"></div>\n                        <div class=\"absolute bottom-8 left-8 right-8\" data-kid=\"171\">\n                            <h4 class=\"text-2xl text-white mb-2\" data-kid=\"172\">Champagne Glow</h4>\n                            <p class=\"text-white/60 text-sm\" data-kid=\"173\">Soft, ethereal pieces that catch the low afternoon sun.</p>\n                        </div>\n                        <div class=\"absolute top-6 right-6 w-8 h-8 rounded-full bg-[var(--color-gold)] flex items-center justify-center\" data-kid=\"174\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"175\"><path d=\"M20 6 9 17l-5-5\" data-kid=\"176\"></path></svg>\n                        </div>\n                    </button>\n                    \n                    <button class=\"group relative overflow-hidden aspect-[3/4] rounded-3xl text-left focus:ring-4 focus:ring-[var(--color-gold)] outline-none transition-all\" data-kid=\"177\">\n                        <img src=\"https://images.pexels.com/photos/12529639/pexels-photo-12529639.png?auto=compress&cs=tinysrgb&w=600&q=80\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110\" alt=\"Option\" data-kid=\"178\">\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-charcoal)]/90 via-transparent to-transparent\" data-kid=\"179\"></div>\n                        <div class=\"absolute bottom-8 left-8 right-8\" data-kid=\"180\">\n                            <h4 class=\"text-2xl text-white mb-2\" data-kid=\"181\">Modernist Edge</h4>\n                            <p class=\"text-white/60 text-sm\" data-kid=\"182\">Sharp architectural forms for the contemporary pioneer.</p>\n                        </div>\n                    </button>\n                </div>\n\n                <div class=\"flex justify-between items-center\" data-kid=\"183\">\n                    <button class=\"text-[var(--color-charcoal)]/40 hover:text-[var(--color-charcoal)] font-bold flex items-center gap-2 transition-colors\" data-kid=\"184\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"185\"><path d=\"m15 18-6-6 6-6\" data-kid=\"186\"></path></svg>\n                        Previous\n                    </button>\n                    <button class=\"bg-[var(--color-gold)] text-white px-12 py-5 rounded-full font-bold shadow-xl shadow-[var(--color-gold)]/20 hover:scale-105 transition-all\" data-kid=\"187\">\n                        Continue Discovery\n                    </button>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 md:py-64 bg-[var(--color-charcoal)] text-[var(--color-beige)] overflow-hidden\" data-kid=\"188\">\n        <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"189\">\n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-32\" data-kid=\"190\">\n                <div class=\"md:col-span-5\" data-kid=\"191\">\n                    <span class=\"text-[var(--color-gold)] font-bold uppercase tracking-[0.5em] text-xs mb-12 block\" data-kid=\"192\">The Client Journal</span>\n                    <h2 class=\"text-6xl md:text-8xl mb-12 font-display leading-[0.85]\" data-kid=\"193\">Voices of <br data-kid=\"194\"><span class=\"italic font-normal\" data-kid=\"195\">Inheritance</span></h2>\n                    <div class=\"w-24 h-24 rounded-full border border-[var(--color-gold)] flex items-center justify-center\" data-kid=\"196\">\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1\" data-kid=\"197\"><path d=\"M12 5v14m-7-7 7 7 7-7\" data-kid=\"198\"></path></svg>\n                    </div>\n                </div>\n                \n                <div class=\"md:col-span-7 space-y-24 md:space-y-48\" data-kid=\"199\">\n                    <div class=\"group\" data-kid=\"200\">\n                        <p class=\"text-3xl md:text-5xl font-display leading-tight italic mb-12 group-hover:text-[var(--color-gold)] transition-colors duration-700\" data-kid=\"201\">\n                            \"The experience of the AI quiz felt more like a personal consultation with a master artisan. I've never felt more 'seen' by a brand's digital presence.\"\n                        </p>\n                        <div class=\"flex items-center gap-6\" data-kid=\"202\">\n                            <img src=\"https://i.pravatar.cc/100?u=6\" class=\"w-20 h-20 rounded-full border-2 border-[var(--color-gold)] shadow-xl\" alt=\"Sienna\" data-kid=\"203\">\n                            <div data-kid=\"204\">\n                                <h5 class=\"text-xl font-bold\" data-kid=\"205\">Sienna Thorne</h5>\n                                <span class=\"text-xs font-bold uppercase tracking-widest text-[var(--color-gold)]\" data-kid=\"206\">Creative Strategist, London</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"group\" data-kid=\"207\">\n                        <p class=\"text-3xl md:text-5xl font-display leading-tight italic mb-12 group-hover:text-[var(--color-gold)] transition-colors duration-700\" data-kid=\"208\">\n                            \"A revolutionary blend of mid-century aesthetics and futuristic technology. My match captures light in ways I didn't think possible.\"\n                        </p>\n                        <div class=\"flex items-center gap-6\" data-kid=\"209\">\n                            <img src=\"https://i.pravatar.cc/100?u=4\" class=\"w-20 h-20 rounded-full border-2 border-[var(--color-gold)] shadow-xl\" alt=\"Helena\" data-kid=\"210\">\n                            <div data-kid=\"211\">\n                                <h5 class=\"text-xl font-bold\" data-kid=\"212\">Helena Ross</h5>\n                                <span class=\"text-xs font-bold uppercase tracking-widest text-[var(--color-gold)]\" data-kid=\"213\">Architect, Copenhagen</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-[var(--color-beige)] pt-32 pb-12 px-6 md:px-12 border-t border-[var(--color-gold)]/20\" data-kid=\"214\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"215\">\n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-16 mb-24\" data-kid=\"216\">\n                <div class=\"md:col-span-4\" data-kid=\"217\">\n                    <a href=\"#\" class=\"text-4xl font-display tracking-tighter italic text-[var(--color-charcoal)] mb-8 block\" data-kid=\"218\">LumaJewels<span class=\"not-italic font-bold\" data-kid=\"219\">AI</span></a>\n                    <p class=\"text-[var(--color-charcoal)]/60 text-lg leading-relaxed mb-10\" data-kid=\"220\">Revolutionizing luxury through the intersection of human craft and machine intelligence. Based in Copenhagen, delivering worldwide.</p>\n                    <div class=\"flex gap-6\" data-kid=\"221\">\n                        <a href=\"#\" class=\"w-12 h-12 rounded-full border border-[var(--color-gold)] flex items-center justify-center text-[var(--color-charcoal)] hover:bg-[var(--color-gold)] hover:text-white transition-all\" data-kid=\"222\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"223\"><rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\" ry=\"5\" data-kid=\"224\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\" data-kid=\"225\"></path><line x1=\"17.5\" y1=\"6.5\" x2=\"17.51\" y2=\"6.5\" data-kid=\"226\"></line></svg>\n                        </a>\n                        <a href=\"#\" class=\"w-12 h-12 rounded-full border border-[var(--color-gold)] flex items-center justify-center text-[var(--color-charcoal)] hover:bg-[var(--color-gold)] hover:text-white transition-all\" data-kid=\"227\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"228\"><path d=\"M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z\" data-kid=\"229\"></path></svg>\n                        </a>\n                        <a href=\"#\" class=\"w-12 h-12 rounded-full border border-[var(--color-gold)] flex items-center justify-center text-[var(--color-charcoal)] hover:bg-[var(--color-gold)] hover:text-white transition-all\" data-kid=\"230\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"231\"><path d=\"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z\" data-kid=\"232\"></path><rect x=\"2\" y=\"9\" width=\"4\" height=\"12\" data-kid=\"233\"></rect><circle cx=\"4\" cy=\"4\" r=\"2\" data-kid=\"234\"></circle></svg>\n                        </a>\n                    </div>\n                </div>\n\n                <div class=\"md:col-span-2 md:col-start-6\" data-kid=\"235\">\n                    <h5 class=\"text-[var(--color-gold)] font-bold uppercase tracking-widest text-xs mb-8\" data-kid=\"236\">Curations</h5>\n                    <ul class=\"space-y-4 text-[var(--color-charcoal)]/80\" data-kid=\"237\">\n                        <li data-kid=\"238\"><a href=\"#\" class=\"hover:text-[var(--color-gold)] transition-colors\" data-kid=\"239\">Bridal Match</a></li>\n                        <li data-kid=\"240\"><a href=\"#\" class=\"hover:text-[var(--color-gold)] transition-colors\" data-kid=\"241\">Evening Gala</a></li>\n                        <li data-kid=\"242\"><a href=\"#\" class=\"hover:text-[var(--color-gold)] transition-colors\" data-kid=\"243\">Executive Wear</a></li>\n                        <li data-kid=\"244\"><a href=\"#\" class=\"hover:text-[var(--color-gold)] transition-colors\" data-kid=\"245\">Limited Series</a></li>\n                    </ul>\n                </div>\n\n                <div class=\"md:col-span-2\" data-kid=\"246\">\n                    <h5 class=\"text-[var(--color-gold)] font-bold uppercase tracking-widest text-xs mb-8\" data-kid=\"247\">Boutique</h5>\n                    <ul class=\"space-y-4 text-[var(--color-charcoal)]/80\" data-kid=\"248\">\n                        <li data-kid=\"249\"><a href=\"#\" class=\"hover:text-[var(--color-gold)] transition-colors\" data-kid=\"250\">AI Concierge</a></li>\n                        <li data-kid=\"251\"><a href=\"#\" class=\"hover:text-[var(--color-gold)] transition-colors\" data-kid=\"252\">Virtual Try-on</a></li>\n                        <li data-kid=\"253\"><a href=\"#\" class=\"hover:text-[var(--color-gold)] transition-colors\" data-kid=\"254\">Ethical Charter</a></li>\n                        <li data-kid=\"255\"><a href=\"#\" class=\"hover:text-[var(--color-gold)] transition-colors\" data-kid=\"256\">Showrooms</a></li>\n                    </ul>\n                </div>\n\n                <div class=\"md:col-span-3\" data-kid=\"257\">\n                    <h5 class=\"text-[var(--color-gold)] font-bold uppercase tracking-widest text-xs mb-8\" data-kid=\"258\">Bespoke Updates</h5>\n                    <p class=\"text-sm text-[var(--color-charcoal)]/60 mb-6\" data-kid=\"259\">Receive early access to our seasonal AI drops and exclusive private viewings.</p>\n                    <form class=\"relative\" data-kid=\"260\">\n                        <input type=\"email\" placeholder=\"Your email address\" class=\"w-full bg-white border border-[var(--color-gold)]/30 rounded-full px-6 py-4 text-sm focus:outline-none focus:border-[var(--color-gold)] transition-colors\" data-kid=\"261\">\n                        <button type=\"submit\" class=\"absolute right-2 top-2 bg-[var(--color-charcoal)] text-white p-2 rounded-full hover:bg-[var(--color-gold)] transition-all\" data-kid=\"262\">\n                            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"263\"><path d=\"M5 12h14m-7-7 7 7-7 7\" data-kid=\"264\"></path></svg>\n                        </button>\n                    </form>\n                </div>\n            </div>\n\n            <div class=\"pt-12 border-t border-[var(--color-gold)]/10 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"265\">\n                <p class=\"text-xs text-[var(--color-charcoal)]/40 font-bold uppercase tracking-widest\" data-kid=\"266\">© 2024 LumaJewels AI. Crafted by Neural Intelligence.</p>\n                <div class=\"flex gap-8\" data-kid=\"267\">\n                    <a href=\"#\" class=\"text-xs text-[var(--color-charcoal)]/40 font-bold uppercase tracking-widest hover:text-[var(--color-gold)] transition-colors\" data-kid=\"268\">Privacy</a>\n                    <a href=\"#\" class=\"text-xs text-[var(--color-charcoal)]/40 font-bold uppercase tracking-widest hover:text-[var(--color-gold)] transition-colors\" data-kid=\"269\">Terms</a>\n                    <a href=\"#\" class=\"text-xs text-[var(--color-charcoal)]/40 font-bold uppercase tracking-widest hover:text-[var(--color-gold)] transition-colors\" data-kid=\"270\">Accessibility</a>\n                </div>\n            </div>\n        </div>\n    </footer>\n</main>\n\n<script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"271\"></script>\n<script data-kid=\"272\">\n    const locomotiveScroll = new LocomotiveScroll({\n        lenisOptions: {\n            duration: 1.5,\n            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n            smoothWheel: true,\n        }\n    });\n\n    // Navigation scroll effect\n    window.addEventListener('scroll', () => {\n        const nav = document.getElementById('main-nav');\n        if (window.scrollY > 100) {\n            nav.classList.add('py-2');\n            nav.classList.remove('py-4');\n        } else {\n            nav.classList.add('py-4');\n            nav.classList.remove('py-2');\n        }\n    });\n</script>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"273\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"274\"></script>\n<script data-kid=\"275\">\n    gsap.registerPlugin(ScrollTrigger);\n\n    // Fade-in animations for cards and sections\n    gsap.utils.toArray('section h2').forEach(heading => {\n        gsap.from(heading, {\n            scrollTrigger: {\n                trigger: heading,\n                start: \"top 90%\",\n                toggleActions: \"play none none reverse\"\n            },\n            y: 50,\n            opacity: 0,\n            duration: 1,\n            ease: \"power3.out\"\n        });\n    });\n\n    // Horizontal scroll snap behavior could be added here if needed, but standard browser scroll is fine with lenis.\n</script>\n",
