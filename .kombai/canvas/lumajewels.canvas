      },
      "html": "<div class=\"bg-[#FFFFF0] text-[#343434] font-['Inter'] selection:bg-[#F7E7CE] overflow-x-clip\" data-kid=\"0\">\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"1\">\n    <style data-kid=\"2\">\n        @import url('https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..900;1,6..96,400..900&family=Inter:wght@300;400;500;600;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n        :root {\n            --color-ivory: #FFFFF0;\n            --color-champagne: #F7E7CE;\n            --color-graphite: #343434;\n        }\n\n        .font-bodoni { font-family: 'Bodoni Moda', serif; }\n        .font-inter { font-family: 'Inter', sans-serif; }\n\n        .glass-panel {\n            border: 1px solid rgba(255, 255, 255, 0.3);\n            background: rgba(255, 255, 255, 0.35);\n            backdrop-filter: blur(24px);\n            box-shadow: \n                0 10px 40px rgba(0, 0, 0, 0.04),\n                inset 0 0 20px rgba(255, 255, 255, 0.2);\n            position: relative;\n        }\n        .glass-panel::after {\n            content: '';\n            position: absolute;\n            inset: 0;\n            border-radius: inherit;\n            padding: 1px;\n            background: linear-gradient(135deg, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0) 100%);\n            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);\n            -webkit-mask-composite: xor;\n            mask-composite: exclude;\n            pointer-events: none;\n        }\n\n        .hairline { border: 1px solid rgba(52, 52, 52, 0.12); }\n        .hairline-b { border-bottom: 1px solid rgba(52, 52, 52, 0.12); }\n        .hairline-t { border-top: 1px solid rgba(52, 52, 52, 0.12); }\n\n        .stamp-seal {\n            border: 1px dashed rgba(52, 52, 52, 0.3);\n            border-radius: 100%;\n        }\n\n        .nav-scrolled {\n            background: rgba(255, 255, 240, 0.85);\n            backdrop-filter: blur(15px);\n            padding-top: 1rem !important;\n            padding-bottom: 1rem !important;\n            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);\n        }\n\n        @keyframes float-subtle {\n            0%, 100% { transform: translateY(0) rotate(0); }\n            50% { transform: translateY(-15px) rotate(1deg); }\n        }\n\n        .animate-float-subtle { animation: float-subtle 8s ease-in-out infinite; }\n        .animate-float-subtle-delayed { animation: float-subtle 8s ease-in-out infinite 2s; }\n\n        .btn-luxe {\n            background: var(--color-graphite);\n            color: var(--color-ivory);\n            transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);\n        }\n        .btn-luxe:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 15px 30px rgba(52, 52, 52, 0.15);\n            background: #1a1a1a;\n        }\n\n        /* Custom Scrollbar */\n        ::-webkit-scrollbar { width: 4px; }\n        ::-webkit-scrollbar-track { background: var(--color-ivory); }\n        ::-webkit-scrollbar-thumb { background: var(--color-graphite); }\n    </style>\n\n    \n    <nav class=\"fixed top-0 w-full z-50 flex justify-between items-center px-6 lg:px-12 py-10 transition-all duration-700\" id=\"main-nav\" data-kid=\"3\">\n        <div class=\"flex items-center gap-2 group cursor-pointer\" data-kid=\"4\">\n            <div class=\"w-8 h-[1px] bg-current transform origin-left group-hover:scale-x-150 transition-transform\" data-kid=\"5\"></div>\n            <div class=\"text-2xl font-bodoni tracking-tighter uppercase\" data-kid=\"6\">LumaJewels</div>\n        </div>\n        <div class=\"hidden md:flex gap-12 text-[9px] tracking-[0.25em] uppercase font-bold\" data-kid=\"7\">\n            <a href=\"#collections\" class=\"hover:opacity-40 transition-opacity\" data-kid=\"8\">Collections</a>\n            <a href=\"#ai-curator\" class=\"hover:opacity-40 transition-opacity\" data-kid=\"9\">AI Curator</a>\n            <a href=\"#philosophy\" class=\"hover:opacity-40 transition-opacity\" data-kid=\"10\">Philosophy</a>\n        </div>\n        <div class=\"flex items-center gap-6\" data-kid=\"11\">\n            <button class=\"hover:opacity-50\" data-kid=\"12\"><i class=\"ti ti-search text-xl\" data-kid=\"13\"></i></button>\n            <div class=\"w-[1px] h-4 bg-current/20\" data-kid=\"14\"></div>\n            <button class=\"flex items-center gap-2 group\" data-kid=\"15\">\n                <i class=\"ti ti-shopping-bag text-xl\" data-kid=\"16\"></i>\n                <span class=\"text-[9px] font-bold tracking-widest hidden sm:block\" data-kid=\"17\">CART (0)</span>\n            </button>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative min-h-[110vh] flex items-center px-6 lg:px-12 overflow-hidden bg-[#FFFFF0]\" id=\"hero\" data-kid=\"18\">\n        <div class=\"container mx-auto grid grid-cols-12 gap-0 relative\" data-kid=\"19\">\n            \n            <div class=\"col-span-12 lg:col-span-8 z-20 pt-32 lg:pt-0\" data-kid=\"20\">\n                <div class=\"reveal-stagger\" data-kid=\"21\">\n                    <div class=\"overflow-hidden mb-4\" data-kid=\"22\">\n                        <span class=\"text-[10px] tracking-[0.4em] uppercase text-[#343434]/60 block font-bold hero-eyebrow\" data-kid=\"23\">Personalized Curation Protocol v4.0</span>\n                    </div>\n                    <h1 class=\"font-bodoni text-[16vw] lg:text-[11vw] leading-[0.8] tracking-tighter mb-10 -ml-2 lg:-ml-4 drop-shadow-sm\" data-kid=\"24\">\n                        Aura<br data-kid=\"25\">\n                        <span class=\"italic font-normal text-[#343434]/90\" data-kid=\"26\">Synthesis.</span>\n                    </h1>\n                    <div class=\"flex flex-col lg:flex-row gap-12 items-start lg:items-center\" data-kid=\"27\">\n                        <p class=\"max-w-xs text-sm text-[#343434]/80 leading-relaxed font-medium\" data-kid=\"28\">\n                            The intersection of digital intelligence and high-jewelry heritage. Experience a collection defined by your unique aesthetic pulse.\n                        </p>\n                        <div class=\"flex gap-4\" data-kid=\"29\">\n                            <button class=\"btn-luxe px-10 py-5 rounded-full text-[10px] tracking-[0.3em] uppercase font-bold flex items-center gap-3\" data-kid=\"30\">\n                                Start Curating <i class=\"ti ti-arrow-right\" data-kid=\"31\"></i>\n                            </button>\n                            <button class=\"hairline px-10 py-5 rounded-full text-[10px] tracking-[0.3em] uppercase font-bold hover:bg-[#343434] hover:text-[#FFFFF0] transition-colors\" data-kid=\"32\">\n                                Play Film\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"col-span-12 lg:col-span-6 lg:absolute lg:right-0 lg:top-1/2 lg:-translate-y-1/2 z-10 mt-12 lg:mt-0\" data-kid=\"33\">\n                <div class=\"relative w-full aspect-[4/5] lg:aspect-[3/4.5] overflow-hidden rounded-[1.5rem] lg:rounded-[3rem] shadow-2xl reveal-up\" data-kid=\"34\">\n                    <img src=\"https://images.unsplash.com/photo-1611652022419-a9419f74343d?auto=format&w=1600&q=90&fit=crop\" alt=\"Model wearing diamond necklace\" class=\"w-full h-full object-cover parallax-hero scale-110\" data-kid=\"35\">\n                    \n                    \n                    <div class=\"absolute bottom-10 left-10 right-10 flex justify-between items-end\" data-kid=\"36\">\n                        <div class=\"glass-panel p-6 rounded-2xl animate-float-subtle w-48\" data-kid=\"37\">\n                            <div class=\"text-[8px] tracking-[0.3em] uppercase text-[#343434]/60 mb-2 font-bold\" data-kid=\"38\">Match Reliability</div>\n                            <div class=\"text-3xl font-bodoni italic\" data-kid=\"39\">92.4%</div>\n                        </div>\n                        <div class=\"glass-panel p-6 rounded-2xl animate-float-subtle-delayed w-48 text-right hidden sm:block\" data-kid=\"40\">\n                            <div class=\"text-[8px] tracking-[0.3em] uppercase text-[#343434]/60 mb-2 font-bold\" data-kid=\"41\">Style Class</div>\n                            <div class=\"text-2xl font-bodoni italic\" data-kid=\"42\">Arch Luxe</div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n        \n        \n        <div class=\"absolute top-1/4 -right-20 w-[600px] h-[600px] bg-[#F7E7CE] rounded-full blur-[140px] -z-10 opacity-30\" data-kid=\"43\"></div>\n    </section>\n\n    \n    <section class=\"py-24 px-6 lg:px-12 border-t hairline\" id=\"collections\" data-kid=\"44\">\n        <div class=\"grid grid-cols-12 gap-12 mb-20\" data-kid=\"45\">\n            <div class=\"col-span-12 lg:col-span-4 reveal-left\" data-kid=\"46\">\n                <h2 class=\"font-bodoni text-5xl lg:text-7xl leading-[0.9] mb-6\" data-kid=\"47\">The Autumn<br data-kid=\"48\"><span class=\"italic\" data-kid=\"49\">Curation.</span></h2>\n                <div class=\"w-16 h-[1px] bg-[#343434] mb-8\" data-kid=\"50\"></div>\n                <p class=\"text-sm text-[#343434]/80 leading-relaxed font-medium mb-10 max-w-sm\" data-kid=\"51\">\n                    Handpicked by our neural network for their structural warmth and temporal balance. Each piece is a digital match for the season's evolving light.\n                </p>\n                <a href=\"#\" class=\"text-[10px] tracking-[0.4em] uppercase font-bold border-b hairline-b pb-1 hover:opacity-50 transition-all\" data-kid=\"52\">Explore Selections</a>\n            </div>\n            \n            <div class=\"col-span-12 lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"53\">\n                <div class=\"reveal-up\" data-kid=\"54\">\n                    <div class=\"aspect-[4/5] overflow-hidden rounded-2xl relative group cursor-pointer\" data-kid=\"55\">\n                        <img src=\"https://images.pexels.com/photos/19895297/pexels-photo-19895297.jpeg?auto=compress&cs=tinysrgb&w=1000&q=80\" class=\"w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-[1.5s]\" data-kid=\"56\">\n                        <div class=\"absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors\" data-kid=\"57\"></div>\n                        <div class=\"absolute bottom-6 left-6 text-white z-20\" data-kid=\"58\">\n                            <h4 class=\"font-bodoni text-3xl italic\" data-kid=\"59\">Aurelia Gold</h4>\n                            <p class=\"text-[9px] tracking-[0.3em] uppercase opacity-70\" data-kid=\"60\">18K Synthesis</p>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"reveal-up\" style=\"transition-delay: 200ms;\" data-kid=\"61\">\n                    <div class=\"aspect-[4/5] overflow-hidden rounded-2xl relative group cursor-pointer lg:mt-12\" data-kid=\"62\">\n                        <img src=\"https://images.unsplash.com/photo-1590166223826-12dee1677420?auto=format&w=1000&q=80&fit=crop\" class=\"w-full h-full object-cover group-hover:scale-105 transition-all duration-[1.5s]\" data-kid=\"63\">\n                        <div class=\"absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors\" data-kid=\"64\"></div>\n                        <div class=\"absolute bottom-6 left-6 text-white z-20\" data-kid=\"65\">\n                            <h4 class=\"font-bodoni text-3xl italic\" data-kid=\"66\">Ethereal Drops</h4>\n                            <p class=\"text-[9px] tracking-[0.3em] uppercase opacity-70\" data-kid=\"67\">Akoya Grade</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 lg:px-12 bg-[#F7E7CE]/20\" id=\"ai-curator\" data-kid=\"68\">\n        <div class=\"grid grid-cols-12 gap-12 lg:gap-24 items-start\" data-kid=\"69\">\n            \n            <div class=\"col-span-12 lg:col-span-2 order-2 lg:order-1 reveal-stagger flex lg:flex-col gap-4\" data-kid=\"70\">\n                <div class=\"mb-4 hidden lg:block\" data-kid=\"71\">\n                    <span class=\"text-[9px] tracking-[0.3em] uppercase font-bold opacity-40\" data-kid=\"72\">Queue</span>\n                </div>\n                <button class=\"spotlight-thumb active relative w-full aspect-square rounded-xl overflow-hidden hairline p-1 transition-all\" data-img=\"https://images.unsplash.com/photo-1616294208582-c2a6d73b467b?auto=format&w=1200&q=80\" data-kid=\"73\">\n                    <img src=\"https://images.unsplash.com/photo-1616294208582-c2a6d73b467b?auto=format&w=200&q=80\" class=\"w-full h-full object-cover rounded-lg\" data-kid=\"74\">\n                </button>\n                <button class=\"spotlight-thumb relative w-full aspect-square rounded-xl overflow-hidden hairline p-1 opacity-40 hover:opacity-100 transition-all\" data-img=\"https://images.unsplash.com/photo-1590166223826-12dee1677420?auto=format&w=1200&q=80\" data-kid=\"75\">\n                    <img src=\"https://images.unsplash.com/photo-1590166223826-12dee1677420?auto=format&w=200&q=80\" class=\"w-full h-full object-cover rounded-lg\" data-kid=\"76\">\n                </button>\n                <button class=\"spotlight-thumb relative w-full aspect-square rounded-xl overflow-hidden hairline p-1 opacity-40 hover:opacity-100 transition-all\" data-img=\"https://images.unsplash.com/photo-1676120963306-8969fa6a810e?auto=format&w=1200&q=80\" data-kid=\"77\">\n                    <img src=\"https://images.unsplash.com/photo-1676120963306-8969fa6a810e?auto=format&w=200&q=80\" class=\"w-full h-full object-cover rounded-lg\" data-kid=\"78\">\n                </button>\n            </div>\n\n            \n            <div class=\"col-span-12 lg:col-span-10 order-1 lg:order-2\" data-kid=\"79\">\n                <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24 items-center\" data-kid=\"80\">\n                    <div class=\"relative reveal-up\" data-kid=\"81\">\n                        <div class=\"aspect-square rounded-[2rem] overflow-hidden shadow-2xl glass-panel p-4\" data-kid=\"82\">\n                            <img src=\"https://images.unsplash.com/photo-1616294208582-c2a6d73b467b?auto=format&w=1400&q=90\" id=\"spotlight-img\" class=\"w-full h-full object-cover rounded-[1.5rem] transition-all duration-1000\" data-kid=\"83\">\n                        </div>\n                        <div class=\"absolute -top-10 -right-10 w-40 h-40 stamp-seal bg-[#FFFFF0] flex items-center justify-center rotate-12 z-30 shadow-2xl\" data-kid=\"84\">\n                            <div class=\"text-[12px] tracking-tighter text-center uppercase font-bold text-[#343434]/80 leading-tight\" data-kid=\"85\">AI MATCHED<br data-kid=\"86\">AUTHENTICATED</div>\n                        </div>\n                    </div>\n                    \n                    <div class=\"reveal-right\" data-kid=\"87\">\n                        <span class=\"text-[10px] tracking-[0.4em] uppercase text-[#343434]/60 mb-6 block font-bold\" data-kid=\"88\">Neural Insight #829</span>\n                        <h2 class=\"font-bodoni text-6xl lg:text-7xl mb-8 leading-[1]\" id=\"spotlight-title\" data-kid=\"89\">Celestial Solitaire.</h2>\n                        \n                        <div class=\"glass-panel p-8 rounded-3xl mb-12\" data-kid=\"90\">\n                            <h5 class=\"font-bodoni text-xl italic mb-3\" data-kid=\"91\">Matching Logic</h5>\n                            <p class=\"text-sm text-[#343434]/80 leading-relaxed font-medium\" id=\"spotlight-desc\" data-kid=\"92\">\n                                The structural symmetry of the Celestial Solitaire offers a direct resonance with your preference for geometric clarity. Verified at 98% match efficiency.\n                            </p>\n                        </div>\n                        \n                        <div class=\"flex items-center justify-between border-b hairline-b pb-8 mb-8\" data-kid=\"93\">\n                            <div class=\"flex flex-col\" data-kid=\"94\">\n                                <span class=\"text-[9px] tracking-[0.2em] uppercase opacity-50 mb-1 font-bold\" data-kid=\"95\">Valuation</span>\n                                <span class=\"text-5xl font-bodoni tracking-tighter\" data-kid=\"96\">$4,250</span>\n                            </div>\n                            <div class=\"glass-panel px-6 py-3 rounded-full text-[10px] tracking-widest font-bold\" data-kid=\"97\">MATCH 98%</div>\n                        </div>\n                        \n                        <button class=\"btn-luxe w-full py-6 rounded-full text-[10px] tracking-[0.3em] uppercase font-bold flex items-center justify-center gap-4\" data-kid=\"98\">\n                            Acquire Selection <i class=\"ti ti-lock-access\" data-kid=\"99\"></i>\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 lg:px-12 bg-[#FFFFF0]\" id=\"philosophy\" data-kid=\"100\">\n        <div class=\"max-w-5xl mx-auto\" data-kid=\"101\">\n            <div class=\"mb-20 reveal-up\" data-kid=\"102\">\n                <h3 class=\"font-bodoni text-4xl lg:text-6xl mb-6\" data-kid=\"103\">The Manifesto.</h3>\n                <p class=\"text-sm text-[#343434]/60 font-bold tracking-[0.1em] uppercase\" data-kid=\"104\">Computational Excellence in High Jewellery</p>\n            </div>\n            \n            <div class=\"space-y-0 reveal-stagger\" data-kid=\"105\">\n                <div class=\"grid grid-cols-1 lg:grid-cols-4 py-12 hairline-b items-center gap-4 lg:gap-12 group hover:bg-[#F7E7CE]/20 transition-colors duration-500 px-4 -mx-4 rounded-lg\" data-kid=\"106\">\n                    <span class=\"text-[10px] tracking-[0.2em] uppercase font-extrabold\" data-kid=\"107\">Provenance</span>\n                    <span class=\"col-span-2 text-sm text-[#343434]/80 leading-relaxed font-medium\" data-kid=\"108\">Direct lineage from Antwerp heritage ateliers with immutable ledger tracking.</span>\n                    <span class=\"text-right font-bodoni text-2xl italic group-hover:translate-x-[-10px] transition-transform duration-500\" data-kid=\"109\">100% Traceable</span>\n                </div>\n                <div class=\"grid grid-cols-1 lg:grid-cols-4 py-10 hairline-b items-center gap-4 lg:gap-12\" data-kid=\"110\">\n                    <span class=\"text-[10px] tracking-[0.2em] uppercase font-extrabold\" data-kid=\"111\">Synthesis</span>\n                    <span class=\"col-span-2 text-sm text-[#343434]/80 leading-relaxed font-medium\" data-kid=\"112\">Proprietary AI curating your aesthetic narrative across digital centuries.</span>\n                    <span class=\"text-right font-bodoni text-2xl italic\" data-kid=\"113\">Neural Matched</span>\n                </div>\n                <div class=\"grid grid-cols-1 lg:grid-cols-4 py-10 hairline-b items-center gap-4 lg:gap-12\" data-kid=\"114\">\n                    <span class=\"text-[10px] tracking-[0.2em] uppercase font-extrabold\" data-kid=\"115\">Certification</span>\n                    <span class=\"col-span-2 text-sm text-[#343434]/80 leading-relaxed font-medium\" data-kid=\"116\">GIA certified gems verified via decentralized verification protocols.</span>\n                    <span class=\"text-right font-bodoni text-2xl italic\" data-kid=\"117\">Vault Assured</span>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 lg:px-12 bg-[#F7E7CE]/10\" id=\"quiz\" data-kid=\"118\">\n        <div class=\"max-w-4xl mx-auto text-center reveal-up\" data-kid=\"119\">\n            <h2 class=\"font-bodoni text-6xl lg:text-8xl italic mb-16\" data-kid=\"120\">Define Your<br data-kid=\"121\">Essence.</h2>\n            <div class=\"space-y-12\" data-kid=\"122\">\n                <p class=\"font-bodoni text-3xl lg:text-4xl text-[#343434]/80 leading-snug\" id=\"quiz-question\" data-kid=\"123\">\n                    \"What occasion defines your <br data-kid=\"124\"> current narrative chapter?\"\n                </p>\n                <div class=\"flex flex-wrap justify-center gap-4 lg:gap-8\" id=\"quiz-options\" data-kid=\"125\">\n                    <button class=\"px-10 py-5 hairline rounded-full text-[11px] tracking-[0.2em] uppercase font-bold hover:bg-[#343434] hover:text-[#FFFFF0] transition-all duration-500\" data-kid=\"126\">Daily Rituals</button>\n                    <button class=\"px-10 py-5 hairline rounded-full text-[11px] tracking-[0.2em] uppercase font-bold bg-[#343434] text-[#FFFFF0] shadow-2xl transition-all duration-500\" data-kid=\"127\">Celestial Gala</button>\n                    <button class=\"px-10 py-5 hairline rounded-full text-[11px] tracking-[0.2em] uppercase font-bold hover:bg-[#343434] hover:text-[#FFFFF0] transition-all duration-500\" data-kid=\"128\">Modern Bridal</button>\n                    <button class=\"px-10 py-5 hairline rounded-full text-[11px] tracking-[0.2em] uppercase font-bold hover:bg-[#343434] hover:text-[#FFFFF0] transition-all duration-500\" data-kid=\"129\">Legacy Piece</button>\n                </div>\n                <button class=\"text-[10px] tracking-[0.3em] uppercase font-bold opacity-30 hover:opacity-100 transition-opacity mt-12 block mx-auto\" data-kid=\"130\">Skip the audit</button>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-40 px-6 lg:px-12 bg-[#FFFFF0] relative overflow-hidden\" data-kid=\"131\">\n        <div class=\"absolute -top-20 -left-20 text-[30rem] font-bodoni italic opacity-[0.03] select-none pointer-events-none\" data-kid=\"132\">“</div>\n        <div class=\"max-w-4xl mx-auto text-center reveal-up\" data-kid=\"133\">\n            <blockquote class=\"font-bodoni text-4xl lg:text-6xl italic leading-tight text-[#343434] mb-12 relative z-10\" id=\"testimonial-text\" data-kid=\"134\">\n                \"The AI didn't just find a piece; it articulated an aesthetic I hadn't yet named. It felt like a digital mirror of my soul.\"\n            </blockquote>\n            <div class=\"flex flex-col items-center gap-4\" data-kid=\"135\">\n                <div class=\"w-12 h-[1px] bg-[#343434]/30 mb-2\" data-kid=\"136\"></div>\n                <cite class=\"text-[10px] tracking-[0.4em] uppercase font-bold not-italic\" id=\"testimonial-author\" data-kid=\"137\">Vogue Editorial</cite>\n                <div class=\"text-[10px] tracking-[0.2em] opacity-40 font-bold mt-4\" id=\"testimonial-counter\" data-kid=\"138\">01 / 03</div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"py-12 px-6 lg:px-12 bg-white hairline-t\" data-kid=\"139\">\n        <div class=\"flex flex-col lg:flex-row justify-between items-center gap-12\" data-kid=\"140\">\n            <div data-kid=\"141\">\n                <div class=\"text-3xl font-bodoni tracking-tighter uppercase mb-2\" data-kid=\"142\">LumaJewels</div>\n                <p class=\"text-[9px] tracking-[0.2em] opacity-30 uppercase font-bold\" data-kid=\"143\">© 2024 Computational Luxury Ateliers.</p>\n            </div>\n            \n            <div class=\"flex gap-12 text-[10px] tracking-[0.3em] uppercase font-bold\" data-kid=\"144\">\n                <a href=\"#\" class=\"hover:opacity-40 transition-opacity\" data-kid=\"145\">Archive</a>\n                <a href=\"#\" class=\"hover:opacity-40 transition-opacity\" data-kid=\"146\">Privacy</a>\n                <a href=\"#\" class=\"hover:opacity-40 transition-opacity\" data-kid=\"147\">Logistics</a>\n                <a href=\"#\" class=\"hover:opacity-40 transition-opacity\" data-kid=\"148\">Journal</a>\n            </div>\n\n            <div class=\"flex items-center gap-6 border-b hairline-b pb-2 group\" data-kid=\"149\">\n                <input type=\"email\" placeholder=\"JOIN THE CIRCLE\" class=\"bg-transparent text-[10px] tracking-[0.3em] outline-none w-48 font-bold\" data-kid=\"150\">\n                <button class=\"text-[#343434] group-hover:translate-x-2 transition-transform\" data-kid=\"151\"><i class=\"ti ti-arrow-right\" data-kid=\"152\"></i></button>\n            </div>\n        </div>\n    </footer>\n\n    \n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"153\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"154\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/TextPlugin.min.js\" data-kid=\"155\"></script>\n    <script type=\"module\" data-kid=\"156\">\n        import Lenis from \"https://esm.sh/lenis@1\"\n\n        // Initialize Lenis\n        const lenis = new Lenis({\n            autoRaf: true,\n            duration: 1.4,\n            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n            touchMultiplier: 1.8\n        });\n\n        // GSAP Setup\n        gsap.registerPlugin(ScrollTrigger, TextPlugin);\n        lenis.on('scroll', ScrollTrigger.update);\n\n        // Nav Scroll Effect\n        window.addEventListener('scroll', () => {\n            const nav = document.getElementById('main-nav');\n            if (window.scrollY > 100) {\n                nav.classList.add('nav-scrolled');\n            } else {\n                nav.classList.remove('nav-scrolled');\n            }\n        });\n\n        // Entrances\n        document.querySelectorAll('.reveal-up').forEach((el) => {\n            gsap.from(el, {\n                scrollTrigger: { trigger: el, start: \"top 90%\" },\n                opacity: 0, y: 40, duration: 1.2, ease: \"power3.out\"\n            });\n        });\n\n        document.querySelectorAll('.reveal-stagger').forEach((container) => {\n            gsap.from(container.children, {\n                scrollTrigger: { trigger: container, start: \"top 85%\" },\n                opacity: 0, y: 30, duration: 1, stagger: 0.15, ease: \"power2.out\"\n            });\n        });\n\n        document.querySelectorAll('.reveal-left').forEach((el) => {\n            gsap.from(el, {\n                scrollTrigger: { trigger: el, start: \"top 90%\" },\n                opacity: 0, x: -40, duration: 1.2, ease: \"power3.out\"\n            });\n        });\n\n        document.querySelectorAll('.reveal-right').forEach((el) => {\n            gsap.from(el, {\n                scrollTrigger: { trigger: el, start: \"top 90%\" },\n                opacity: 0, x: 40, duration: 1.2, ease: \"power3.out\"\n            });\n        });\n\n        // Parallax\n        gsap.to(\".parallax-hero\", {\n            scrollTrigger: { trigger: \"#hero\", start: \"top top\", end: \"bottom top\", scrub: true },\n            y: \"10%\", ease: \"none\"\n        });\n\n        // Spotlight Switcher\n        const thumbs = document.querySelectorAll('.spotlight-thumb');\n        const mainImg = document.getElementById('spotlight-img');\n        const titles = [\"Celestial Solitaire.\", \"Ethereal Drops.\", \"Liquid Synthesis.\", \"Aurelia Narrative.\"];\n        const descs = [\n            \"The structural symmetry of the Celestial Solitaire offers a direct resonance with your preference for geometric clarity.\",\n            \"Hand-picked Akoya pearls synthesized into a fluid architecture of light and shadow.\",\n            \"Contemporary silver forged through digital algorithmic patterns for an organic yet precise form.\",\n            \"18K gold narrative pieces curated to articulate your legacy through computational elegance.\"\n        ];\n\n        thumbs.forEach((thumb, i) => {\n            thumb.addEventListener('click', () => {\n                thumbs.forEach(t => t.classList.remove('active', 'opacity-100', 'hairline-black'));\n                thumbs.forEach(t => t.classList.add('opacity-40'));\n                thumb.classList.add('active', 'opacity-100');\n                thumb.classList.remove('opacity-40');\n\n                gsap.to(mainImg, {\n                    opacity: 0, scale: 0.98, duration: 0.3,\n                    onComplete: () => {\n                        mainImg.src = thumb.dataset.img;\n                        gsap.to(mainImg, { opacity: 1, scale: 1, duration: 0.7 });\n                    }\n                });\n\n                gsap.to(\"#spotlight-title\", { duration: 0.6, text: { value: titles[i], delimiter: \" \" } });\n                gsap.to(\"#spotlight-desc\", { duration: 0.6, text: { value: descs[i], delimiter: \" \" } });\n            });\n        });\n\n        // Rotating Testimonial\n        const quotes = [\n            { text: '\"The AI didn\\'t just find a piece; it articulated an aesthetic I hadn\\'t yet named. It felt like a digital mirror of my soul.\"', author: 'Vogue Editorial', count: '01 / 03' },\n            { text: '\"Finally, a curation protocol that understands the intersection of digital precision and emotional heritage.\"', author: 'Harpers Bazaar', count: '02 / 03' },\n            { text: '\"Uncannily precise. LumaJewels is the architect of future luxury, defining the new standard of personal choice.\"', author: 'Tatler Review', count: '03 / 03' }\n        ];\n        let qIdx = 0;\n        setInterval(() => {\n            qIdx = (qIdx + 1) % quotes.length;\n            const q = quotes[qIdx];\n            gsap.to(\"#testimonial-text\", { opacity: 0, y: -10, duration: 0.6, onComplete: () => {\n                document.getElementById(\"testimonial-text\").innerText = q.text;\n                document.getElementById(\"testimonial-author\").innerText = q.author;\n                document.getElementById(\"testimonial-counter\").innerText = q.count;\n                gsap.to(\"#testimonial-text\", { opacity: 1, y: 0, duration: 0.6 });\n            }});\n        }, 8000);\n    </script>\n</div>",
